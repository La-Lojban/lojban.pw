# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# Dependency directories and files
node_modules
/.pnp
.pnp.js
src/.pnpm-store/*

# Build output and cache files
.next
src/out/
data/.cache
src/tsconfig.tsbuildinfo
tmp/
archive/

# Environment variable files
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Package manager and debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Test coverage and story snapshots
/coverage
.specstory/*
data/pages/.specstory/*

# Miscellaneous system and private files
.DS_Store
*.pem

# Scripts and temporary folders
scripts/
!src/scripts/

# Project-specific ignored files
data/pages/texts