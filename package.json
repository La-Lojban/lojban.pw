{
  "name": "lojban-made-easy",
  "version": "2.0.0",
  "packageManager": "pnpm@10.33.0",
  "private": true,
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "go": "pnpm install ; pnpm build:test ; pnpm start",
    "dev": "NODE_NO_WARNINGS=1 NODE_ENV=development next dev --webpack",
    "start": "pnpm clearup-serve && python3 -m http.server 3000 --directory out",
    "compile": "pnpm build && pkill node",
    "cicd": "pnpm build  && mkdir -p out1 && cp -rT out out1 && pnpm clean",
    "build-core": "next build",
    "build": "pnpm clearup-serve && pnpm korpora && pnpm build-core && node scripts/generate-sitemap.js && pnpm print && touch out/.nojekyll && node scripts/run-with-paths.js sh -c 'cp -avr ${SERVICE_PATH}/* out/ && cp -avr ${VREJI_PATH} out/' && pnpm cleanup",
    "build:test": "NODE_OPTIONS='--max-old-space-size=4096' pnpm clearup-serve && next build && node scripts/generate-sitemap.js && touch out/.nojekyll && node scripts/run-with-paths.js sh -c 'cp -avr ${SERVICE_PATH}/* out/ && cp -avr ${VREJI_PATH} out/' && pnpm cleanup",
    "korpora": "node scripts/run-with-paths.js sh -c 'rm -rf ${TMP_PATH}/korpora && mkdir -p ${TMP_PATH}/korpora && rm -rf ${MD_PAGES_PATH}/texts && mkdir -p ${MD_PAGES_PATH}/texts' && tsx lib/korpora/index.ts",
    "print": "node scripts/run-with-paths.js sh ./lib/printer/run-print.sh",
    "clearup-serve": "lsof -t -i:3000 | xargs --no-run-if-empty kill -9 && next telemetry disable",
    "cleanup": "node scripts/run-with-paths.js sh -c 'rm -rf ${MD_PAGES_PATH}/text'",
    "algolia-index": "node scripts/algolia-index.js",
    "korpora:cnino": "tsx scripts/korpora.ts",
    "validate:dialogues": "tsx scripts/validate-lojban-through-dialogues-spiral.ts",
    "clean": "rm -rf .next",
    "typecheck": "tsc"
  },
  "dependencies": {
    "@headlessui/react": "^2.2.9",
    "@heroicons/react": "^2.2.0",
    "algoliasearch": "^5.19.0",
    "html-react-parser": "^5.2.10",
    "next": "^16.2.2",
    "node-html-parser": "^7.1.0",
    "react": "^19",
    "react-dom": "^19",
    "react-image-gallery": "^2.1.2",
    "react-instantsearch": "^7.29.0",
    "simple-icons": "^13",
    "socket.io-client": "^4.8.3",
    "unist-util-is": "^6.0.1",
    "unist-util-visit": "^5.1.0",
    "vfile": "^6.0.3"
  },
  "devDependencies": {
    "@gradio/client": "^2.0.0",
    "@openrouter/sdk": "^0.2.9",
    "@types/archiver": "^6.0.2",
    "@types/jsdom": "^21.1.7",
    "@types/mdast": "^4.0.4",
    "@types/node": "^22.5.2",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/react-image-gallery": "^1.2.4",
    "@types/unist": "^3.0.3",
    "archiver": "^7.0.1",
    "dotenv": "^17.2.3",
    "google-spreadsheet": "^5.2.0",
    "gray-matter": "^4.0.3",
    "jsdom": "^25.0.1",
    "mermaid": "^11.14.0",
    "playwright": "^1.59.1",
    "playwright-core": "^1.59.1",
    "postcss": "^8.5.8",
    "prettier": "^3.8.1",
    "rehype-katex": "^7.0.1",
    "rehype-parse": "^8.0.4",
    "rehype-raw": "^6.1.1",
    "rehype-stringify": "^9.0.3",
    "remark-definition-list": "^1.2.0",
    "remark-gfm": "^3.0.1",
    "remark-math": "^5.1.0",
    "remark-parse": "^10.0.1",
    "remark-rehype": "^10.1.0",
    "sharp": "^0.34.5",
    "svgo": "^3.3.3",
    "tailwind-scrollbar": "^3.1.0",
    "tailwindcss": "3.4.17",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "unified": "^10.1.2"
  },
  "license": "MIT",
  "pnpm": {
    "overrides": {
      "vfile": "^6.0.3",
      "vfile-message": "^4.0.3",
      "axios": ">=0.30.3",
      "minimatch": ">=9.0.7",
      "immutable": ">=5.1.5",
      "lodash": ">=4.17.23",
      "lodash-es": ">=4.17.23",
      "dompurify": ">=3.3.2",
      "diff": ">=5.2.2"
    }
  }
}
