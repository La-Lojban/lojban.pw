_semantic_search"],"hidden":false,"title":"la sutysisku et la recherche de similarité","directory":"fr"},{"slug":["fr","books","core-lojban"],"hidden":false,"title":"📝 Essai sur le « Lojban de base »","directory":"fr"},{"slug":["fr","books","learn-lojban"],"hidden":false,"title":"🎓 Apprenez le lojban","directory":"fr"},{"slug":["fr","questions","grimace-in-lojban"],"hidden":false,"title":"La notion de grimace dans la langue Lojban","directory":"fr"},{"slug":["fr","questions","history-of-lojban"],"hidden":false,"title":"Histoire du Lojban","directory":"fr"},{"slug":["fr","welcome"],"hidden":false,"title":"Qu'est-ce que le Lojban ?","directory":"fr"},{"slug":["humour","sapir-whorf-hypothesis-confirmed"],"hidden":false,"title":"Sapir-Whorf hypothesis confirmed!","directory":"humour"},{"slug":["pt","articles","are-verbs-in-lojban-broken"],"hidden":false,"title":"Os Verbos em Lojban estão Quebrados?","directory":"pt"},{"slug":["pt","articles","complete-lojban-language"],"hidden":false,"title":"📕 Idioma completo","directory":"pt"},{"slug":["pt","articles","dialects"],"hidden":false,"title":"Dialectos do Lojban","directory":"pt"},{"slug":["pt","articles","how-to-say-play-in-lojban"],"hidden":false,"title":"Como dizer \"jogar\" em Lojban","directory":"pt"},{"slug":["pt","articles","krulermorna"],"hidden":false,"title":"alfabeto krulermorna","directory":"pt"},{"slug":["pt","articles","live_chat"],"hidden":false,"title":"💬 Chat","directory":"pt"},{"slug":["pt","articles","lojban-and-speed-of-thought"],"hidden":false,"title":"Língua Lojban e velocidade do pensamento","directory":"pt"},{"slug":["pt","articles","sutysisku-picture-dictionary"],"hidden":false,"title":"la sutysisku: dicionário de imagens","directory":"pt"},{"slug":["pt","articles","sutysisku_semantic_search"],"hidden":false,"title":"la sutysisku e busca de similaridade","directory":"pt"},{"slug":["pt","books","core-lojban"],"hidden":false,"title":"📝 Ensaio 'Core Lojban'","directory":"pt"},{"slug":["pt","books","lea