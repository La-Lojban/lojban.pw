ru","articles","complete-lojban-language"],"hidden":false,"title":"📕 Грамматика","directory":"ru"},{"slug":["ru","articles","dialects"],"hidden":false,"title":"Диалекты Ложбана","directory":"ru"},{"slug":["ru","articles","how-to-say-play-in-lojban"],"hidden":false,"title":"Как сказать \"играть\" на языке Ложбан","directory":"ru"},{"slug":["ru","articles","krulermorna"],"hidden":false,"title":"алфавит krulermorna","directory":"ru"},{"slug":["ru","articles","live_chat"],"hidden":false,"title":"💬 Чат","directory":"ru"},{"slug":["ru","articles","lojban-and-speed-of-thought"],"hidden":false,"title":"Язык Ложбан и скорость мышления","directory":"ru"},{"slug":["ru","articles","sutysisku-picture-dictionary"],"hidden":false,"title":"la sutysisku: иллюстрированный словарь","directory":"ru"},{"slug":["ru","articles","sutysisku_semantic_search"],"hidden":false,"title":"la sutysisku и поиск похожих слов","directory":"ru"},{"slug":["ru","books","!lojban-patterns"],"hidden":true,"title":"🧩 «Алгоритмы и шаблоны на Lojban, Haskell, Rust, JavaScript»","directory":"ru"},{"slug":["ru","books","core-lojban"],"hidden":false,"title":"📝 Эссе \"Основы Ложбана\"","directory":"ru"},{"slug":["ru","books","learn-lojban"],"hidden":false,"title":"🎓 Изучаем ложбан","directory":"ru"},{"slug":["ru","books","prostaya-logika"],"hidden":false,"title":"Зачем нужна логика?","directory":"ru"},{"slug":["ru","questions","grimace-in-lojban"],"hidden":false,"title":"Понятие гримасы в языке Ложбан","directory":"ru"},{"slug":["ru","questions","history-of-lojban"],"hidden":false,"title":"История Ложбана","directory":"ru"},{"slug":["ru","texts","a-terrorist-he-is-watching"],"hidden":false,"title":"Террорист, он смотрит.","directory":"ru"},{"slug":["ru","texts","alice-in-wonderland"],"hidden":false,"title":"Алиса в Стране Чудес","directory":"ru"},{"slug":["ru","texts","how-the-enemy-came-to-thlunrana"],"hidden":false,"title":"Как Враг пришел в Тлунрану","directory":"ru"},{"slug":["ru","texts","in-a-bitter-hour"],"hidden":false,"title":"В горький час","directory":"ru"},{"slug":["ru","texts","jokes"],"hidden":false,"title":"Анекдоты","directory":"ru"},{"slug":["ru","texts","lords-prayer"],"hidden":false,"title":"The Lord's prayer","directory":"ru"},{"slug":["ru","texts","navy-seal-copypasta"],"hidden":false,"title":"Navy Seals","directory":"ru"},{"slug":["ru","texts","terry-the-tiger-visits-the-big-city"],"hidden":false,"title":"Тигренок Терри посещает большой город.","directory":"ru"},{"slug":["ru","texts","the-bad-beginning"],"hidden":false,"title":"Скверное начало","directory":"ru"},{"slug":["ru","texts","the-book"],"hidden":false,"title":"Книга","directory":"ru"},{"slug":["ru","texts","the-girl-from-ipanema"],"hidden":false,"title":"Garota da Ipanema","directory":"ru"},{"slug":["ru","texts","the-mask"],"hidden":false,"title":"Маска","directory":"ru"},{"slug":["ru","texts","the-north-wind-and-the-sun"],"hidden":false,"title":"Северный ветер и солнце","directory":"ru"},{"slug":["ru","texts","there-will-come-soft-rains"],"hidden":false,"title":"Придут тихие дожди","directory":"ru"},{"slug":["ru","texts","to-kill-a-child"],"hidden":false,"title":"Убить ребёнка","directory":"ru"},{"slug":["ru","texts"],"hidden":false,"title":"📚 Корпус текстов","directory":"ru"},{"slug":["ru","welcome"],"hidden":false,"title":"Что такое ложбан?","directory":"ru"}],"currentLanguage":"fr","post":{"slug":["fr","articles","krulermorna"],"title":"alphabet krulermorna","hidden":false,"content":"<p><strong>la krulermorna</strong> est une orthographe alternative qui met en œuvre de manière plus stricte l'isomorphisme audiovisuel de l'orthographe en Lojban.</p>\n<ol>\n<li>La plupart des lettres proviennent de l'orthographe originale basée sur l'alphabet latin.</li>\n<li>Les glisses <strong>i</strong> et <strong>u</strong> devant les voyelles sont considérées comme des consonnes et sont donc exprimées par des lettres distinctes :\n<ul>\n<li><strong>i</strong> => <strong>ɩ</strong></li>\n<li><strong>u</strong> => <strong>w</strong></li>\n</ul>\n</li>\n<li>Les diphtongues qui se comportent comme d'autres voyelles \"pures\" sont exprimées par des lettres distinctes :\n<ul>\n<li><strong>au</strong> => <strong>ǎ</strong></li>\n<li><strong>ai</strong> => <strong>ą</strong></li>\n<li><strong>ei</strong> => <strong>ę</strong></li>\n<li><strong>oi</strong> => <strong>ǫ</strong></li>\n</ul>\n</li>\n<li>Dans d'autres positions, <strong>i</strong> et <strong>u</strong> sont conservés tels quels dans l'orthographe originale en alphabet latin.</li>\n</ol>\n<h2 id=\"utilisation\">Utilisation<a class=\"print:hidden\" aria-hidden=\"true\" tabindex=\"-1\" href=\"#utilisation\"><span class=\"in-heading hash\">#</span></a></h2>\n<p>la krulermorna est utilisée par un algorithme dans l'application <a href=\"https://la-lojban.github.io/sutysisku/fr/\" title=\"la sutysisku\">la sutysisku</a> pour rechercher des rimes pour les mots en Lojban.</p>\n<p>Cela peut également aider à comprendre la morphologie du Lojban.</p>\n<p>Mis à part cela, c'est principalement un projet artistique.</p>\n<p>Le nombre total de lettres dans l'alphabet Lojban passe de 26 dans l'orthographe officielle à 32 dans la krulermorna, ce qui peut ne pas être souhaitable pour les personnes utilisant de petits claviers d'écran comme ceux des appareils portables.</p>\n<h2 id=\"la-vlipa-krulermorna\">la vlipa krulermorna<a class=\"print:hidden\" aria-hidden=\"true\" tabindex=\"-1\" href=\"#la-vlipa-krulermorna\"><span class=\"in-heading hash\">#</span></a></h2>\n<figure class=\"wide\">\n\t<img src=\"https://github.com/La-Lojban/suho-pixra-pe-la-jbotcan/blob/master/320px-la_vlipa_krulermorna.png?raw=true\" alt=\"la vlipa krulermorna\">\n\t<figcaption>\n\t.i coi do<br>.i mi ca jai gau djuno fai do<br>lo du'u wi mi ca pilno<br>la krulermorna<br>lo ka ciska dei<br>.i ɩa ky. jai cinri\n\t</figcaption>\n</figure>\n<p><em>la vlipa krulermorna</em> est une modification de la krulermorna où la lettre <strong>ǎ</strong> est remplacée par le caractère Unicode 'LATIN SMALL LETTER AU'. Ce dernier n'est pas pris en charge par la plupart des polices utilisées et donc cette variante de l'orthographe krulermorna est moins utilisée.</p>\n<h2 id=\"interjections-selon-krulerske\">Interjections selon krulerske<a class=\"print:hidden\" aria-hidden=\"true\" tabindex=\"-1\" href=\"#interjections-selon-krulerske\"><span class=\"in-heading hash\">#</span></a></h2>\n<p>|          |           |              |        |\n| -------- | --------- | ------------ | ------ |\n| .ǎ       | .ą        | .ę           | .ǫ     |\n| Désir ... | Je vais    | cela devrait | ouille! |</p>\n<div class=\"first_col\">\n<p>|     | a               | e                | i                   | o             | u               |\n| --- | --------------- | ---------------- | ------------------- | ------------- | --------------- |\n| .   |                 |                  |                     |               |                 |\n| ɩ   | Je crois        | oua! d'accord! | ouh là là!          | respect       | J'adore ça      |\n| w   | découverte      | Quelle surprise  | hourra!            | voilà!       | oh pauvre chose |\n| .a' | j'écoute        | vigilance        | ouf! (effort)      | J'espère       | hum, je me demande... |\n| .e' | tu peux         | allez, fais-le! | fais-le!           | s'il te plaît, fais-le | Je suggère       |\n| .i' | d'accord, je l'accepte | J'approuve! | Je connais ce sentiment | grâce à ça  | familiarité     |\n| .o' | fierté           | proximité        | danger!            | patience      | relaxation      |\n| .u' | gain            | quelle merveille!  | hahaha!            | courage       | désolé!         |</p>\n</div>\n<h2 id=\"représentation-alternative\">Représentation alternative<a class=\"print:hidden\" aria-hidden=\"true\" tabindex=\"-1\" href=\"#représentation-alternative\"><span class=\"in-heading hash\">#</span></a></h2>\n<div class=\"first_col\">\n<p>|     | a          | e          | i            | o            | u           | ǎ      | ą      | ę          | ǫ              |\n| --- | ---------- | ---------- | ------------ | ------------ | ----------- | ------ | ------ | ---------- | -------------- |\n| .   |            |            |              |              |             | désir  | intention | obligation | plainte/douleur |\n| ɩ   | croyance     | accord  | peur         | respect      | amour        |        |        |            |                |\n| w   | découverte  | surprise   | bonheur    | achèvement   | pitié        |        |        |            |                |\n| .a' | attentif/ve  | vigilance  | effort       | espoir         | intérêt    |        |        |            |                |\n| .e' | permission | compétence | contrainte   | demande      | suggestion  |        |        |            |                |\n| .i' | acceptation | approbation   | être ensemble | appréciation | familiarité |        |        |            |                |\n| .o' | fierté      | proximité  | prudence      | patience     | détente  |        |        |            |                |\n| .u' | gain       | émerveillement   | amusement    | courage      | repentir  |        |        |            |                |</p>\n</div>","fullPath":"/app/src/md_pages/fr/articles/krulermorna.md","toc":[{"depth":"2","value":"Utilisation","id":"utilisation","tagName":"h2"},{"depth":"2","value":"la vlipa krulermorna","id":"la-vlipa-krulermorna","tagName":"h2"},{"depth":"2","value":"Interjections selon krulerske","id":"interjections-selon-krulerske","tagName":"h2"},{"depth":"2","value":"Représentation alternative","id":"représentation-alternative","tagName":"h2"}],"imgs":[]}},"__N_SSG":true}