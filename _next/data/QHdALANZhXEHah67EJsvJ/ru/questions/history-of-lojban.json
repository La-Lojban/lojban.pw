{"pageProps":{"posts":[{"fullPath":"en/questions/history-of-lojban","language":"en"},{"fullPath":"es/questions/history-of-lojban","language":"es"},{"fullPath":"fr/questions/history-of-lojban","language":"fr"},{"fullPath":"pt/questions/history-of-lojban","language":"pt"}],"allPosts":[{"slug":["en","articles","are-verbs-in-lojban-broken"],"hidden":false,"title":"Are Verbs in Lojban Broken?","directory":"en"},{"slug":["en","articles","complete-lojban-language"],"hidden":false,"title":"📕 Complete language","directory":"en"},{"slug":["en","articles","dialects"],"hidden":false,"title":"Dialects of Lojban","directory":"en"},{"slug":["en","articles","how-to-say-play-in-lojban"],"hidden":false,"title":"How to say \"play\" in Lojban","directory":"en"},{"slug":["en","articles","krulermorna"],"hidden":false,"title":"krulermorna alphabet","directory":"en"},{"slug":["en","articles","live_chat"],"hidden":false,"title":"💬 Live chat","directory":"en"},{"slug":["en","articles","lojban-and-speed-of-thought"],"hidden":false,"title":"Lojban language and speed of thought","directory":"en"},{"slug":["en","articles","sutysisku-picture-dictionary"],"hidden":false,"title":"la sutysisku: picture dictionary","directory":"en"},{"slug":["en","articles","sutysisku_semantic_search"],"hidden":false,"title":"la sutysisku and similarity search","directory":"en"},{"slug":["en","books","!lojban-patterns"],"hidden":true,"title":"🧩 ‘Algorithms and patterns in Lojban, Haskell, Rust, JavaScript’","directory":"en"},{"slug":["en","books","core-lojban"],"hidden":false,"title":"📝 ‘Core Lojban’ essay","directory":"en"},{"slug":["en","books","learn-lojban"],"hidden":false,"title":"🎓 Learn Lojban","directory":"en"},{"slug":["en","humour","sapir-whorf-hypothesis-confirmed"],"hidden":false,"title":"Sapir-Whorf hypothesis confirmed!","directory":"en"},{"slug":["en","questions","grimace-in-lojban"],"hidden":false,"title":"The notion of grimace in Lojban language","directory":"en"},{"slug":["en","questions","history-o