slug":["es","texts","lords-prayer"],"hidden":false,"title":"The Lord's prayer","directory":"es"},{"slug":["es","texts","navy-seal-copypasta"],"hidden":false,"title":"Navy Seals","directory":"es"},{"slug":["es","texts","terry-the-tiger-visits-the-big-city"],"hidden":false,"title":"Terry the Tiger","directory":"es"},{"slug":["es","texts","the-bad-beginning"],"hidden":false,"title":"The Bad Beginning","directory":"es"},{"slug":["es","texts","the-book"],"hidden":false,"title":"The Book","directory":"es"},{"slug":["es","texts","the-girl-from-ipanema"],"hidden":false,"title":"Garota da Ipanema","directory":"es"},{"slug":["es","texts","the-mask"],"hidden":false,"title":"La máscara","directory":"es"},{"slug":["es","texts","the-north-wind-and-the-sun"],"hidden":false,"title":"The North Wind","directory":"es"},{"slug":["es","texts","there-will-come-soft-rains"],"hidden":false,"title":"Soft rains","directory":"es"},{"slug":["es","texts","to-kill-a-child"],"hidden":false,"title":"To kill a child","directory":"es"},{"slug":["es","texts"],"hidden":false,"title":"📚 Corpus de textos","directory":"es"},{"slug":["es","welcome"],"hidden":false,"title":"¿Qué es Lojban?","directory":"es"},{"slug":["fr","articles","are-verbs-in-lojban-broken"],"hidden":false,"title":"Des verbes compliqués en lojban ?","directory":"fr"},{"slug":["fr","articles","complete-lojban-language"],"hidden":false,"title":"📕 Langue complète","directory":"fr"},{"slug":["fr","articles","dialects"],"hidden":false,"title":"Dialectes de Lojban","directory":"fr"},{"slug":["fr","articles","how-to-say-play-in-lojban"],"hidden":false,"title":"Comment dire \"jouer\" en lojban","directory":"fr"},{"slug":["fr","articles","krulermorna"],"hidden":false,"title":"alphabet krulermorna","directory":"fr"},{"slug":["fr","articles","live_chat"],"hidden":false,"title":"💬 Chat","directory":"fr"},{"slug":["fr","articles","lojban-and-speed-of-thought"],"hidden":false,"title":"Langue lojban et vitesse de la pensée","directory":"fr"},{"slug":