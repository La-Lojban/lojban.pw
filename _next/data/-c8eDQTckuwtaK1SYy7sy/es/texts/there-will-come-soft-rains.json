{"pageProps":{"posts":[{"fullPath":"en/texts/there-will-come-soft-rains","language":"en"},{"fullPath":"fr/texts/there-will-come-soft-rains","language":"fr"},{"fullPath":"pt/texts/there-will-come-soft-rains","language":"pt"},{"fullPath":"ru/texts/there-will-come-soft-rains","language":"ru"}],"siblingPosts":[{"slug":["es","articles","are-verbs-in-lojban-broken"],"hidden":false,"title":"¿Están rotos los verbos en Lojban?","directory":"es"},{"slug":["es","articles","complete-lojban-language"],"hidden":false,"title":"📕 Idioma completo","directory":"es"},{"slug":["es","articles","dialects"],"hidden":false,"title":"Dialectos de Lojban","directory":"es"},{"slug":["es","articles","how-to-say-play-in-lojban"],"hidden":false,"title":"Cómo decir \"jugar\" en Lojban","directory":"es"},{"slug":["es","articles","krulermorna"],"hidden":false,"title":"alfabeto krulermorna","directory":"es"},{"slug":["es","articles","live_chat"],"hidden":false,"title":"💬 Chat","directory":"es"},{"slug":["es","articles","lojban-and-speed-of-thought"],"hidden":false,"title":"Lenguaje Lojban y velocidad del pensamiento","directory":"es"},{"slug":["es","articles","sutysisku-picture-dictionary"],"hidden":false,"title":"la sutysisku: diccionario de imágenes","directory":"es"},{"slug":["es","articles","sutysisku_semantic_search"],"hidden":false,"title":"la sutysisku y la búsqueda de similitud","directory":"es"},{"slug":["es","books","learn-lojban"],"hidden":false,"title":"🎓 Aprende Lojban","directory":"es","coverImage":"/assets/pixra/cilre/tcidu_la_lojban.webp"},{"slug":["es","humour","sapir-whorf-hypothesis-confirmed"],"hidden":false,"title":"¡Hipótesis de Sapir-Whorf confirmada!","directory":"es"},{"slug":["es","list"],"hidden":false,"title":"📑 Mapa del sitio","directory":"es"},{"slug":["es","questions","grimace-in-lojban"],"hidden":false,"title":"La noción de mueca en el idioma Lojban","directory":"es"},{"slug":["es","questions","history-of-lojban"],"hidden":false,"title":"Historia de Lojban","directory":"es"},{"slug":["es","texts","a-terrorist-he-is-watching"],"hidden":false,"title":"A terrorist, he is watching","directory":"es"},{"slug":["es","texts","alice-in-wonderland"],"hidden":false,"title":"Alice in Wonderland","directory":"es"},{"slug":["es","texts","how-the-enemy-came-to-thlunrana"],"hidden":false,"title":"De cómo llegó el enemigo a Thulnrana.","directory":"es"},{"slug":["es","texts","in-a-bitter-hour"],"hidden":false,"title":"In A Bitter Hour","directory":"es"},{"slug":["es","texts","jokes"],"hidden":false,"title":"Jokes","directory":"es"},{"slug":["es","texts","lords-prayer"],"hidden":false,"title":"Lord's prayer","directory":"es"},{"slug":["es","texts","navy-seal-copypasta"],"hidden":false,"title":"Navy Seal Copypasta","directory":"es"},{"slug":["es","texts","terry-the-tiger-visits-the-big-city"],"hidden":false,"title":"Terry el Tigre Visita la Gran Ciudad","directory":"es"},{"slug":["es","texts","the-bad-beginning"],"hidden":false,"title":"The Bad Beginning","directory":"es"},{"slug":["es","texts","the-book"],"hidden":false,"title":"El Libro","directory":"es"},{"slug":["es","texts","the-girl-from-ipanema"],"hidden":false,"title":"The Girl from Ipanema","directory":"es"},{"slug":["es","texts","the-mask"],"hidden":false,"title":"La máscara","directory":"es"},{"slug":["es","texts","the-north-wind-and-the-sun"],"hidden":false,"title":"The North Wind and the Sun","directory":"es"},{"slug":["es","texts","there-will-come-soft-rains"],"hidden":false,"title":"There Will Come Soft Rains","directory":"es"},{"slug":["es","texts","to-kill-a-child"],"hidden":false,"title":"Matar a un niño","directory":"es"},{"slug":["es","texts"],"hidden":false,"title":"📚 Corpus de textos","directory":"es"},{"slug":["es","welcome"],"hidden":false,"title":"¿Qué es Lojban?","directory":"es"}],"currentLanguage":"es","post":{"slug":["es","texts","there-will-come-soft-rains"],"title":"There Will Come Soft Rains","hidden":false,"meta.description":"There Will Come Soft Rains - by Sara Teasdale","meta.keywords":"ba milxe bo carvi, There Will Come Soft Rains, There will be mild rains, Придут тихие дожди, Il y aura de douces pluies","meta.author":"by Sara Teasdale","meta.type":"korpora","content":"<div class=\"w-full\">\n  <input type=\"checkbox\" id=\"hide-column-lojbo\" class=\"hide-column-checkbox-lojbo\">\n  <label for=\"hide-column-lojbo\" class=\"hide-column-button-lojbo float-left drop-shadow bg-teal-100 hover:bg-teal-600 focus:bg-teal-600 text-gray-900 hover:text-white font-bold leading-normal select-none py-2 px-4\">lojbo</label><input type=\"checkbox\" id=\"hide-column-glico\" class=\"hide-column-checkbox-glico\">\n  <label for=\"hide-column-glico\" class=\"hide-column-button-glico float-left drop-shadow bg-teal-100 hover:bg-teal-600 focus:bg-teal-600 text-gray-900 hover:text-white font-bold leading-normal select-none py-2 px-4\">English</label><input type=\"checkbox\" id=\"hide-column-glico_gi_e_te_fanva_fo_le_lojbo\" class=\"hide-column-checkbox-glico_gi_e_te_fanva_fo_le_lojbo\">\n  <label for=\"hide-column-glico_gi_e_te_fanva_fo_le_lojbo\" class=\"hide-column-button-glico_gi_e_te_fanva_fo_le_lojbo float-left drop-shadow bg-teal-100 hover:bg-teal-600 focus:bg-teal-600 text-gray-900 hover:text-white font-bold leading-normal select-none py-2 px-4\">glico gi'e te fanva fo le lojbo</label><input type=\"checkbox\" id=\"hide-column-rusko\" class=\"hide-column-checkbox-rusko\">\n  <label for=\"hide-column-rusko\" class=\"hide-column-button-rusko float-left drop-shadow bg-teal-100 hover:bg-teal-600 focus:bg-teal-600 text-gray-900 hover:text-white font-bold leading-normal select-none py-2 px-4\">русский</label><input type=\"checkbox\" id=\"hide-column-fraso\" class=\"hide-column-checkbox-fraso\">\n  <label for=\"hide-column-fraso\" class=\"hide-column-button-fraso float-left drop-shadow bg-teal-100 hover:bg-teal-600 focus:bg-teal-600 text-gray-900 hover:text-white font-bold leading-normal select-none py-2 px-4\">français</label>\n  <div class=\"clear-both\">\n  <div class=\"w-full overflow-x-auto\">\n    <div class=\"md-typeset__scrollwrap\"><div class=\"md-typeset__scrollwrap\"><div class=\"md-typeset__table\"><table class=\"mt-2 table-fixed max-w-full border font-light dark:border-neutral-500 text-left text-sm\">\n      <thead class=\"border-b italic dark:border-neutral-500\">\n        <tr>\n          <th scope=\"col\" class=\"w-40 p-2 column-class-lojbo\">lojbo</th>\n          <th scope=\"col\" class=\"w-40 p-2 column-class-glico\">glico</th>\n          <th scope=\"col\" class=\"w-40 p-2 column-class-glico_gi_e_te_fanva_fo_le_lojbo\">\n            glico gi'e te fanva fo le lojbo\n          </th>\n          <th scope=\"col\" class=\"w-40 p-2 column-class-rusko\">rusko</th>\n          <th scope=\"col\" class=\"w-40 p-2 column-class-fraso\">fraso</th>\n        </tr>\n      </thead>\n      <tbody>\n        <tr class=\"border-b transition duration-300 ease-in-out hover:bg-neutral-100 dark:border-neutral-500 dark:hover:bg-neutral-100\">\n          <td class=\"font-bold text-left align-text-top p-2 column-class-lojbo\">\n            ni'o ni'o bau le lojbo\n          </td>\n          <td class=\"font-bold text-left align-text-top p-2 column-class-glico\">\n            English original\n          </td>\n          <td class=\"font-bold text-left align-text-top p-2 column-class-glico_gi_e_te_fanva_fo_le_lojbo\">\n            Back translation from Lojban\n          </td>\n          <td class=\"font-bold text-left align-text-top p-2 column-class-rusko\">\n            Русский перевод\n          </td>\n          <td class=\"font-bold text-left align-text-top p-2 column-class-fraso\">\n            Version française\n          </td>\n        </tr>\n        <tr class=\"border-b transition duration-300 ease-in-out hover:bg-neutral-100 dark:border-neutral-500 dark:hover:bg-neutral-100\">\n          <td class=\"text-left align-text-top p-2 column-class-lojbo\">\n            ba milxe bo carvi\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-glico\">\n            There Will Come Soft Rains\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-glico_gi_e_te_fanva_fo_le_lojbo\">\n            There will be mild rains\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-rusko\">\n            Придут тихие дожди\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-fraso\">\n            Il y aura de douces pluies\n          </td>\n        </tr>\n        <tr class=\"border-b transition duration-300 ease-in-out hover:bg-neutral-100 dark:border-neutral-500 dark:hover:bg-neutral-100\">\n          <td class=\"text-left align-text-top p-2 column-class-lojbo\">\n            .i finti fa la .saras.tizdeil.\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-glico\">\n            by Sara Teasdale\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-glico_gi_e_te_fanva_fo_le_lojbo\">\n            Sara Teasdale invented.\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-rusko\">\n            Автор Сара Тисдейл\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-fraso\">\n            Écrit par Sara Teasdale\n          </td>\n        </tr>\n        <tr class=\"border-b transition duration-300 ease-in-out hover:bg-neutral-100 dark:border-neutral-500 dark:hover:bg-neutral-100\">\n          <td class=\"text-left align-text-top p-2 column-class-lojbo\">\n            .i fanva fa la gleki\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-glico\">\n            English original\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-glico_gi_e_te_fanva_fo_le_lojbo\">\n            la gleki\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-rusko\">\n            Перевод la gleki\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-fraso\">\n            Original anglais\n          </td>\n        </tr>\n        <tr class=\"border-b transition duration-300 ease-in-out hover:bg-neutral-100 dark:border-neutral-500 dark:hover:bg-neutral-100\">\n          <td class=\"text-left align-text-top p-2 column-class-lojbo\">\n            .i ba milxe bo carvi .i panci lo dertu\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-glico\">\n            There will come soft rains and the smell of the ground,\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-glico_gi_e_te_fanva_fo_le_lojbo\">\n            There will be mild rains. It smells of the ground.\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-rusko\">\n            Придут тихие дожди и запах земли,\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-fraso\">\n            Il y aura de douces pluies et l'odeur du sol,\n          </td>\n        </tr>\n        <tr class=\"border-b transition duration-300 ease-in-out hover:bg-neutral-100 dark:border-neutral-500 dark:hover:bg-neutral-100\">\n          <td class=\"text-left align-text-top p-2 column-class-lojbo\">\n            .i le cipni ba sutra bo vofli co certu\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-glico\">\n            And swallows circling with their shimmering sound;\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-glico_gi_e_te_fanva_fo_le_lojbo\">\n            Birds will skillfully rapidly fly.\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-rusko\">\n            И ласточки будут кружить с мерцающим звуком;\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-fraso\">\n            Et les hirondelles qui tournent en rond avec leur son chatoyant ;\n          </td>\n        </tr>\n        <tr class=\"border-b transition duration-300 ease-in-out hover:bg-neutral-100 dark:border-neutral-500 dark:hover:bg-neutral-100\">\n          <td class=\"text-left align-text-top p-2 column-class-lojbo\">\n            .i le banfi ba sanga .i melbi bo vanci\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-glico\">\n            And frogs in the pools singing at night,\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-glico_gi_e_te_fanva_fo_le_lojbo\">\n            The frogs will sing. It is a beautiful evening.\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-rusko\">\n            И лягушки в бассейнах будут петь по ночам,\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-fraso\">\n            Et les grenouilles dans les mares chantant la nuit,\n          </td>\n        </tr>\n        <tr class=\"border-b transition duration-300 ease-in-out hover:bg-neutral-100 dark:border-neutral-500 dark:hover:bg-neutral-100\">\n          <td class=\"text-left align-text-top p-2 column-class-lojbo\">\n            .i le flaume bo tricu ba blabi se manci\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-glico\">\n            And wild plum trees in tremulous white,\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-glico_gi_e_te_fanva_fo_le_lojbo\">\n            The plum-trees will be white-marvelous.\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-rusko\">\n            И дикие сливовые деревья в трепетной белизне,\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-fraso\">\n            Et des pruniers sauvages d'un blanc tremblant,\n          </td>\n        </tr>\n        <tr class=\"border-b transition duration-300 ease-in-out hover:bg-neutral-100 dark:border-neutral-500 dark:hover:bg-neutral-100\">\n          <td class=\"text-left align-text-top p-2 column-class-lojbo\">\n            .i le gunse ba dasni le fagri bo pimlu\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-glico\">\n            Robins will wear their feathery fire\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-glico_gi_e_te_fanva_fo_le_lojbo\">\n            Geese will wear fire-feathers.\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-rusko\">\n            Малиновки будут носить свой пернатый огонь\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-fraso\">\n            Les rouges-gorges porteront leurs plumes de feu\n          </td>\n        </tr>\n        <tr class=\"border-b transition duration-300 ease-in-out hover:bg-neutral-100 dark:border-neutral-500 dark:hover:bg-neutral-100\">\n          <td class=\"text-left align-text-top p-2 column-class-lojbo\">\n            gi'e siclu fe le jai se gleki co simlu\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-glico\">\n            Whistling their whims on a low fence-wire;\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-glico_gi_e_te_fanva_fo_le_lojbo\">\n            and whistle seemingly happy melodies.\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-rusko\">\n            Насвистывая свои прихоти на низкой проволочной изгороди;\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-fraso\">\n            Sifflant leurs caprices sur un fil de clôture bas ;\n          </td>\n        </tr>\n        <tr class=\"border-b transition duration-300 ease-in-out hover:bg-neutral-100 dark:border-neutral-500 dark:hover:bg-neutral-100\">\n          <td class=\"text-left align-text-top p-2 column-class-lojbo\">\n            .i se slabu le jamna fa no cmalu danlu\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-glico\">\n            And not one will know of the war, not one\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-glico_gi_e_te_fanva_fo_le_lojbo\">\n            No small animal will know the warriors.\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-rusko\">\n            И никто не узнает о войне, никому\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-fraso\">\n            Et personne ne saura rien de la guerre, personne\n          </td>\n        </tr>\n        <tr class=\"border-b transition duration-300 ease-in-out hover:bg-neutral-100 dark:border-neutral-500 dark:hover:bg-neutral-100\">\n          <td class=\"text-left align-text-top p-2 column-class-lojbo\">\n            .i no stuzi le xarci ba su'o roi canlu\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-glico\">\n            Will care at last when it is done.\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-glico_gi_e_te_fanva_fo_le_lojbo\">\n            No place will ever be taken by the weapons.\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-rusko\">\n            Не будет дела, когда она пройдет.\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-fraso\">\n            S'inquiétera enfin de la fin de la guerre.\n          </td>\n        </tr>\n        <tr class=\"border-b transition duration-300 ease-in-out hover:bg-neutral-100 dark:border-neutral-500 dark:hover:bg-neutral-100\">\n          <td class=\"text-left align-text-top p-2 column-class-lojbo\">\n            .i no cipni ba xanka fa no jdari tricu\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-glico\">\n            Not one would mind, neither bird nor tree\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-glico_gi_e_te_fanva_fo_le_lojbo\">\n            No bird will worry, neither any strong tree\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-rusko\">\n            Никто не будет возражать, ни птица, ни дерево\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-fraso\">\n            Personne ne s'en soucierait, ni les oiseaux, ni les arbres\n          </td>\n        </tr>\n        <tr class=\"border-b transition duration-300 ease-in-out hover:bg-neutral-100 dark:border-neutral-500 dark:hover:bg-neutral-100\">\n          <td class=\"text-left align-text-top p-2 column-class-lojbo\">\n            fe le fanmo be mi'a noi no da ba skicu\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-glico\">\n            If mankind perished utterly;\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-glico_gi_e_te_fanva_fo_le_lojbo\">\n            about the end of us who no one will tell about.\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-rusko\">\n            Если человечество исчезнет полностью;\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-fraso\">\n            Si l'humanité disparaissait complètement ;\n          </td>\n        </tr>\n        <tr class=\"border-b transition duration-300 ease-in-out hover:bg-neutral-100 dark:border-neutral-500 dark:hover:bg-neutral-100\">\n          <td class=\"text-left align-text-top p-2 column-class-lojbo\">\n            .i la vensa ba cikna ke viska le cmana\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-glico\">\n            And Spring herself, when she woke at dawn,\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-glico_gi_e_te_fanva_fo_le_lojbo\">\n            Spring will awakeningly see the mountains.\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-rusko\">\n            И сама Весна, проснувшись на рассвете,\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-fraso\">\n            Et le printemps lui-même, lorsqu'il se réveillera à l'aube,\n          </td>\n        </tr>\n        <tr class=\"border-b transition duration-300 ease-in-out hover:bg-neutral-100 dark:border-neutral-500 dark:hover:bg-neutral-100\">\n          <td class=\"text-left align-text-top p-2 column-class-lojbo\">\n            .i te mintu le jalge .i vy. ri na zgana\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-glico\">\n            Would scarcely know that we were gone.\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-glico_gi_e_te_fanva_fo_le_lojbo\">\n            The outcome is equal. Spring doesn't observe it.\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-rusko\">\n            едва ли узнает, что нас больше нет.\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-fraso\">\n            Saurait à peine que nous sommes partis.\n          </td>\n        </tr>\n      </tbody>\n    </table></div></div></div>\n  </div>\n</div></div>","fullPath":"/app/src/md_pages/es/texts/there-will-come-soft-rains.md","toc":[],"imgs":[]}},"__N_SSG":true}