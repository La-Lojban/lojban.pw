{"pageProps":{"posts":[{"fullPath":"en/texts/navy-seal-copypasta","language":"en"},{"fullPath":"es/texts/navy-seal-copypasta","language":"es"},{"fullPath":"fr/texts/navy-seal-copypasta","language":"fr"},{"fullPath":"ru/texts/navy-seal-copypasta","language":"ru"}],"siblingPosts":[{"slug":["pt","articles","are-verbs-in-lojban-broken"],"hidden":false,"title":"Os Verbos em Lojban estão Quebrados?","directory":"pt"},{"slug":["pt","articles","complete-lojban-language"],"hidden":false,"title":"📕 Idioma completo","directory":"pt"},{"slug":["pt","articles","dialects"],"hidden":false,"title":"Dialectos do Lojban","directory":"pt"},{"slug":["pt","articles","how-to-say-play-in-lojban"],"hidden":false,"title":"Como dizer \"jogar\" em Lojban","directory":"pt"},{"slug":["pt","articles","krulermorna"],"hidden":false,"title":"alfabeto krulermorna","directory":"pt"},{"slug":["pt","articles","live_chat"],"hidden":false,"title":"💬 Chat","directory":"pt"},{"slug":["pt","articles","lojban-and-speed-of-thought"],"hidden":false,"title":"Língua Lojban e velocidade do pensamento","directory":"pt"},{"slug":["pt","articles","sutysisku-picture-dictionary"],"hidden":false,"title":"la sutysisku: dicionário de imagens","directory":"pt"},{"slug":["pt","articles","sutysisku_semantic_search"],"hidden":false,"title":"la sutysisku e busca de similaridade","directory":"pt"},{"slug":["pt","books","core-lojban"],"hidden":false,"title":"📝 Ensaio 'Core Lojban'","directory":"pt"},{"slug":["pt","books","learn-lojban"],"hidden":false,"title":"🎓 Aprenda Lojban","directory":"pt","coverImage":"/assets/pixra/cilre/tcidu_la_lojban.webp"},{"slug":["pt","humour","sapir-whorf-hypothesis-confirmed"],"hidden":false,"title":"Hipótese de Sapir-Whorf confirmada!","directory":"pt"},{"slug":["pt","list"],"hidden":false,"title":"📑 Mapa do site","directory":"pt"},{"slug":["pt","questions","grimace-in-lojban"],"hidden":false,"title":"A noção de torcer a boca na língua Lojban","directory":"pt"},{"slug":["pt","questions","history-of-lojban"],"hidden":false,"title":"História do Lojban","directory":"pt"},{"slug":["pt","texts","a-terrorist-he-is-watching"],"hidden":false,"title":"A terrorist, he is watching","directory":"pt"},{"slug":["pt","texts","alice-in-wonderland"],"hidden":false,"title":"Alice in Wonderland","directory":"pt"},{"slug":["pt","texts","how-the-enemy-came-to-thlunrana"],"hidden":false,"title":"De como o inimigo chegou a Thlunrana","directory":"pt"},{"slug":["pt","texts","in-a-bitter-hour"],"hidden":false,"title":"In A Bitter Hour","directory":"pt"},{"slug":["pt","texts","jokes"],"hidden":false,"title":"Jokes","directory":"pt"},{"slug":["pt","texts","lords-prayer"],"hidden":false,"title":"Lord's prayer","directory":"pt"},{"slug":["pt","texts","navy-seal-copypasta"],"hidden":false,"title":"Navy Seal Copypasta","directory":"pt"},{"slug":["pt","texts","terry-the-tiger-visits-the-big-city"],"hidden":false,"title":"Terry, o Tigre Visita a Grande Cidade","directory":"pt"},{"slug":["pt","texts","the-bad-beginning"],"hidden":false,"title":"The Bad Beginning","directory":"pt"},{"slug":["pt","texts","the-book"],"hidden":false,"title":"O Livro","directory":"pt"},{"slug":["pt","texts","the-girl-from-ipanema"],"hidden":false,"title":"Garota de Ipanema","directory":"pt"},{"slug":["pt","texts","the-mask"],"hidden":false,"title":"A mascára","directory":"pt"},{"slug":["pt","texts","the-north-wind-and-the-sun"],"hidden":false,"title":"The North Wind and the Sun","directory":"pt"},{"slug":["pt","texts","there-will-come-soft-rains"],"hidden":false,"title":"There Will Come Soft Rains","directory":"pt"},{"slug":["pt","texts","to-kill-a-child"],"hidden":false,"title":"Matar uma criança","directory":"pt"},{"slug":["pt","texts"],"hidden":false,"title":"📚 Corpus de textos","directory":"pt"},{"slug":["pt","welcome"],"hidden":false,"title":"O que é Lojban?","directory":"pt"}],"currentLanguage":"pt","post":{"slug":["pt","texts","navy-seal-copypasta"],"title":"Navy Seal Copypasta","hidden":false,"meta.description":"Navy Seal Copypasta - http://knowyourmeme.com/memes/navy-seal-copypasta","meta.keywords":"Navy Seal Copypasta, la .navisil., la .navisil.","meta.author":"http://knowyourmeme.com/memes/navy-seal-copypasta","meta.type":"korpora","content":"<div class=\"w-full\">\n  <input type=\"checkbox\" id=\"hide-column-glico\" class=\"hide-column-checkbox-glico\">\n  <label for=\"hide-column-glico\" class=\"hide-column-button-glico float-left drop-shadow bg-teal-100 hover:bg-teal-600 focus:bg-teal-600 text-gray-900 hover:text-white font-bold leading-normal select-none py-2 px-4\">English</label><input type=\"checkbox\" id=\"hide-column-lojbo_gi_e_se_fanva_la_gleki\" class=\"hide-column-checkbox-lojbo_gi_e_se_fanva_la_gleki\">\n  <label for=\"hide-column-lojbo_gi_e_se_fanva_la_gleki\" class=\"hide-column-button-lojbo_gi_e_se_fanva_la_gleki float-left drop-shadow bg-teal-100 hover:bg-teal-600 focus:bg-teal-600 text-gray-900 hover:text-white font-bold leading-normal select-none py-2 px-4\">lojbo gi'e se fanva la gleki</label><input type=\"checkbox\" id=\"hide-column-lojbo_fi_e_se_fanva_la_pimlu\" class=\"hide-column-checkbox-lojbo_fi_e_se_fanva_la_pimlu\">\n  <label for=\"hide-column-lojbo_fi_e_se_fanva_la_pimlu\" class=\"hide-column-button-lojbo_fi_e_se_fanva_la_pimlu float-left drop-shadow bg-teal-100 hover:bg-teal-600 focus:bg-teal-600 text-gray-900 hover:text-white font-bold leading-normal select-none py-2 px-4\">lojbo fi'e se fanva la pimlu</label>\n  <div class=\"clear-both\">\n  <div class=\"w-full overflow-x-auto\">\n    <div class=\"md-typeset__scrollwrap\"><div class=\"md-typeset__scrollwrap\"><div class=\"md-typeset__table\"><table class=\"mt-2 table-fixed max-w-full border font-light dark:border-neutral-500 text-left text-sm\">\n      <thead class=\"border-b italic dark:border-neutral-500\">\n        <tr>\n          <th scope=\"col\" class=\"w-40 p-2 column-class-glico\">glico</th>\n          <th scope=\"col\" class=\"w-40 p-2 column-class-lojbo_gi_e_se_fanva_la_gleki\">\n            lojbo gi'e se fanva la gleki\n          </th>\n          <th scope=\"col\" class=\"w-40 p-2 column-class-lojbo_fi_e_se_fanva_la_pimlu\">\n            lojbo fi'e se fanva la pimlu\n          </th>\n        </tr>\n      </thead>\n      <tbody>\n        <tr class=\"border-b transition duration-300 ease-in-out hover:bg-neutral-100 dark:border-neutral-500 dark:hover:bg-neutral-100\">\n          <td class=\"font-bold text-left align-text-top p-2 column-class-glico\">\n            English original\n          </td>\n          <td class=\"font-bold text-left align-text-top p-2 column-class-lojbo_gi_e_se_fanva_la_gleki\">\n            ni'o ni'o bau le lojbo\n          </td>\n          <td class=\"font-bold text-left align-text-top p-2 column-class-lojbo_fi_e_se_fanva_la_pimlu\">\n            ni'o ni'o bau le lojbo\n          </td>\n        </tr>\n        <tr class=\"border-b transition duration-300 ease-in-out hover:bg-neutral-100 dark:border-neutral-500 dark:hover:bg-neutral-100\">\n          <td class=\"text-left align-text-top p-2 column-class-glico\">\n            Navy Seal Copypasta\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-lojbo_gi_e_se_fanva_la_gleki\">\n            la .navisil.\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-lojbo_fi_e_se_fanva_la_pimlu\">\n            la .navisil.\n          </td>\n        </tr>\n        <tr class=\"border-b transition duration-300 ease-in-out hover:bg-neutral-100 dark:border-neutral-500 dark:hover:bg-neutral-100\">\n          <td class=\"text-left align-text-top p-2 column-class-glico\">\n            http://knowyourmeme.com/memes/navy-seal-copypasta\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-lojbo_gi_e_se_fanva_la_gleki\"></td>\n          <td class=\"text-left align-text-top p-2 column-class-lojbo_fi_e_se_fanva_la_pimlu\"></td>\n        </tr>\n        <tr class=\"border-b transition duration-300 ease-in-out hover:bg-neutral-100 dark:border-neutral-500 dark:hover:bg-neutral-100\">\n          <td class=\"text-left align-text-top p-2 column-class-glico\">\n            English original\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-lojbo_gi_e_se_fanva_la_gleki\">\n            .i fanva fa la gleki\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-lojbo_fi_e_se_fanva_la_pimlu\">\n            .i fanva fa la pimlu\n          </td>\n        </tr>\n        <tr class=\"border-b transition duration-300 ease-in-out hover:bg-neutral-100 dark:border-neutral-500 dark:hover:bg-neutral-100\">\n          <td class=\"text-left align-text-top p-2 column-class-glico\">\n            What the fuck did you just fucking say about me, you little bitch?\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-lojbo_gi_e_se_fanva_la_gleki\">\n            .i sei mabla ma mabla se smusku do gi'e srana mi doi cmalu gerku\n            pe'a\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-lojbo_fi_e_se_fanva_la_pimlu\">\n            .i ma pe mi do ga'i mabla se cusku\n          </td>\n        </tr>\n        <tr class=\"border-b transition duration-300 ease-in-out hover:bg-neutral-100 dark:border-neutral-500 dark:hover:bg-neutral-100\">\n          <td class=\"text-left align-text-top p-2 column-class-glico\">\n            I’ll have you know I graduated top of my class in the Navy Seals,\n            and I’ve been involved in numerous secret raids on Al-Quaeda, and I\n            have over 300 confirmed kills.\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-lojbo_gi_e_se_fanva_la_gleki\">\n            .i ko djuno le du'u mi traji le ka zabna vau fo le'i mo'u tadni be\n            bu'u la .nevisils. gi'e pu'i so'i roi smaji gunta la alkaida .i je\n            fatci fa le du'u mi catra za'u ci no no prenu\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-lojbo_fi_e_se_fanva_la_pimlu\">\n            .i .eidai do djuno lodu'u mi kulmu'o co xagrai lo tadni la\n            .nevi.sils. gi'e so'iroi mipri gunta la .al.kaidas. gi'e za'u cinono\n            roi birti catra\n          </td>\n        </tr>\n        <tr class=\"border-b transition duration-300 ease-in-out hover:bg-neutral-100 dark:border-neutral-500 dark:hover:bg-neutral-100\">\n          <td class=\"text-left align-text-top p-2 column-class-glico\">\n            I am trained in gorilla warfare and I’m the top sniper in the entire\n            US armed forces.\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-lojbo_gi_e_se_fanva_la_gleki\">\n            .i mi certu le ka jamna fau le nu mi cmima lo so'u mei jenmi .i je\n            mi traji le ka zabna vau fo le'i jai gau cecla pe le merko bilni\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-lojbo_fi_e_se_fanva_la_pimlu\">\n            .i mi certu loka tsasmani jamna kei gi'e crerai loka satcygunta kei\n            lo merko bilni\n          </td>\n        </tr>\n        <tr class=\"border-b transition duration-300 ease-in-out hover:bg-neutral-100 dark:border-neutral-500 dark:hover:bg-neutral-100\">\n          <td class=\"text-left align-text-top p-2 column-class-glico\">\n            You are nothing to me but just another target.\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-lojbo_gi_e_se_fanva_la_gleki\">\n            .i do mi se xarci sa'u\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-lojbo_fi_e_se_fanva_la_pimlu\">\n            .i do ma'i mi se xarci po'o\n          </td>\n        </tr>\n        <tr class=\"border-b transition duration-300 ease-in-out hover:bg-neutral-100 dark:border-neutral-500 dark:hover:bg-neutral-100\">\n          <td class=\"text-left align-text-top p-2 column-class-glico\">\n            I will wipe you the fuck out with precision the likes of which has\n            never been seen before on this Earth, mark my fucking words.\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-lojbo_gi_e_se_fanva_la_gleki\">\n            .i mi ba mabla vimcu do i je le nu go'i cu satci le no roi se zgana\n            be bu'u le terdi .i ko jundi le mi mabla zabna valsi\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-lojbo_fi_e_se_fanva_la_pimlu\">\n            .i mi ba mabla vimcu do soi lo simsa be ke'a noroi se zgana vi lo\n            terdi\n          </td>\n        </tr>\n        <tr class=\"border-b transition duration-300 ease-in-out hover:bg-neutral-100 dark:border-neutral-500 dark:hover:bg-neutral-100\">\n          <td class=\"text-left align-text-top p-2 column-class-glico\">\n            You think you can get away with saying that shit to me over the\n            Internet?\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-lojbo_gi_e_se_fanva_la_gleki\">\n            .i xu do krici le du'u do kakne le ka rivbi va'o le nu do cusku le\n            bi'u nai mabla fo le kibro\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-lojbo_fi_e_se_fanva_la_pimlu\">\n            .i xu krici lodu'u kakne lonu kibro cusku lo mabla gi'e rivbi\n          </td>\n        </tr>\n        <tr class=\"border-b transition duration-300 ease-in-out hover:bg-neutral-100 dark:border-neutral-500 dark:hover:bg-neutral-100\">\n          <td class=\"text-left align-text-top p-2 column-class-glico\">\n            Think again, fucker.\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-lojbo_gi_e_se_fanva_la_gleki\">\n            .i ko za'u re'u pensi doi jai se bapli\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-lojbo_fi_e_se_fanva_la_pimlu\">\n            .i ko za'ure'u mabla jurpei\n          </td>\n        </tr>\n        <tr class=\"border-b transition duration-300 ease-in-out hover:bg-neutral-100 dark:border-neutral-500 dark:hover:bg-neutral-100\">\n          <td class=\"text-left align-text-top p-2 column-class-glico\">\n            As we speak I am contacting my secret network of spies across the\n            USA\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-lojbo_gi_e_se_fanva_la_gleki\">\n            .i ca le nu mi'o casnu vau mi cusku fo le mi sivni se tcana be le\n            sivni zgana bei ve'u le merko\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-lojbo_fi_e_se_fanva_la_pimlu\">\n            .i ca lonu mi'o casnu ku mi tavla lo mi mipri seltcana be loi\n            mipyzga bei ve'u lo merko\n          </td>\n        </tr>\n        <tr class=\"border-b transition duration-300 ease-in-out hover:bg-neutral-100 dark:border-neutral-500 dark:hover:bg-neutral-100\">\n          <td class=\"text-left align-text-top p-2 column-class-glico\">\n            and your IP is being traced right now so you better prepare for the\n            storm, maggot.\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-lojbo_gi_e_se_fanva_la_gleki\">\n            .i ji'a le judri be do bei le kibro pu'o jai se facki i se ki'u bo\n            do cu e'u bredi tu'a lo vlile doi jerna be no da\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-lojbo_fi_e_se_fanva_la_pimlu\">\n            .iji'a lo do samjudri ca se cipcta semu'i lonu .e'u do do bregau\n            tu'a lo vilti'a\n          </td>\n        </tr>\n        <tr class=\"border-b transition duration-300 ease-in-out hover:bg-neutral-100 dark:border-neutral-500 dark:hover:bg-neutral-100\">\n          <td class=\"text-left align-text-top p-2 column-class-glico\">\n            The storm that wipes out the pathetic little thing you call your\n            life.\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-lojbo_gi_e_se_fanva_la_gleki\">\n            .i ri jai rinka le nu lo ruble co'u fasnu .i je ri se renvi do\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-lojbo_fi_e_se_fanva_la_pimlu\">\n            .i ri jai daspo lo ruble po'u lo li'i do jmive\n          </td>\n        </tr>\n        <tr class=\"border-b transition duration-300 ease-in-out hover:bg-neutral-100 dark:border-neutral-500 dark:hover:bg-neutral-100\">\n          <td class=\"text-left align-text-top p-2 column-class-glico\">\n            You’re fucking dead, kid.\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-lojbo_gi_e_se_fanva_la_gleki\">\n            .i do ga'i mabla morsi\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-lojbo_fi_e_se_fanva_la_pimlu\">\n            .i do ga'i malmro\n          </td>\n        </tr>\n        <tr class=\"border-b transition duration-300 ease-in-out hover:bg-neutral-100 dark:border-neutral-500 dark:hover:bg-neutral-100\">\n          <td class=\"text-left align-text-top p-2 column-class-glico\">\n            I can be anywhere, anytime, and I can kill you in over seven hundred\n            ways, and that’s just with my bare hands.\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-lojbo_gi_e_se_fanva_la_gleki\">\n            .i ro da poi stuzi vau ro de poi se tcika zo'u mi ka'e zvati bu'u da\n            pe'e ja ca de .i je za'u ze no no tadji le nu da'i mi jai gau morsi\n            fai do ca le nu ta'o mi pilno lei po'o xance be mi\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-lojbo_fi_e_se_fanva_la_pimlu\">\n            .i mi ka'e zvati ro stuzi ca ro mokca gi'e ka'e mrogau do ta'i za'u\n            zenono da sepi'o lo po'o mi xance\n          </td>\n        </tr>\n        <tr class=\"border-b transition duration-300 ease-in-out hover:bg-neutral-100 dark:border-neutral-500 dark:hover:bg-neutral-100\">\n          <td class=\"text-left align-text-top p-2 column-class-glico\">\n            Not only am I extensively trained in unarmed combat, but I have\n            access to the entire arsenal of the United States Marine Corps\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-lojbo_gi_e_se_fanva_la_gleki\">\n            .i ge mi certu le ka pilno no xarci le ka damba gi ji'a ro da poi\n            xarci fi le merko ke xamsi se sonci zo'u mi se krali le ka pilno da\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-lojbo_fi_e_se_fanva_la_pimlu\">\n            .i mi bancre loka nalxarci damba kei gi'e ji'a se gubni ro lo xarci\n            poi se ponse lo mergu'e\n          </td>\n        </tr>\n        <tr class=\"border-b transition duration-300 ease-in-out hover:bg-neutral-100 dark:border-neutral-500 dark:hover:bg-neutral-100\">\n          <td class=\"text-left align-text-top p-2 column-class-glico\">\n            and I will use it to its full extent to wipe your miserable ass off\n            the face of the continent, you little shit.\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-lojbo_gi_e_se_fanva_la_gleki\">\n            .i je mi ba pilno su'o xarci bi'u nai se la'u li ro le ka vimcu le\n            mabla ganxo be do le flira pe'a be le braplu doi cmalu kalci pe'a\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-lojbo_fi_e_se_fanva_la_pimlu\">\n            .i ba pilno lo xagrai be lo xarci loka jisygau lo braplu do\n          </td>\n        </tr>\n        <tr class=\"border-b transition duration-300 ease-in-out hover:bg-neutral-100 dark:border-neutral-500 dark:hover:bg-neutral-100\">\n          <td class=\"text-left align-text-top p-2 column-class-glico\">\n            If only you could have known what unholy retribution your little\n            “clever” comment was about to bring down upon you,\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-lojbo_gi_e_se_fanva_la_gleki\">\n            .i da'i pu ku ga nai do djuno le du'u pu'o to'e censa cnemu do le ka\n            stati ia dai piksku vau ma kau\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-lojbo_fi_e_se_fanva_la_pimlu\">\n            .i da'i do pu djuno lodu'u makau tolcesna tolne'u fi loka do\n            menstati ba'e simlu be fi do se pinka\n          </td>\n        </tr>\n        <tr class=\"border-b transition duration-300 ease-in-out hover:bg-neutral-100 dark:border-neutral-500 dark:hover:bg-neutral-100\">\n          <td class=\"text-left align-text-top p-2 column-class-glico\">\n            maybe you would have held your fucking tongue.\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-lojbo_gi_e_se_fanva_la_gleki\">\n            gi ju'o cu'i do mabla smaji\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-lojbo_fi_e_se_fanva_la_pimlu\">\n            .isemu'ibo do mabla smaji\n          </td>\n        </tr>\n        <tr class=\"border-b transition duration-300 ease-in-out hover:bg-neutral-100 dark:border-neutral-500 dark:hover:bg-neutral-100\">\n          <td class=\"text-left align-text-top p-2 column-class-glico\">\n            But you couldn’t, you didn’t,\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-lojbo_gi_e_se_fanva_la_gleki\">\n            .i ku'i do na kakne gi'e na ckaji\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-lojbo_fi_e_se_fanva_la_pimlu\">\n            .iku'i do na kakne loka go'i gi'e na ckaji ri\n          </td>\n        </tr>\n        <tr class=\"border-b transition duration-300 ease-in-out hover:bg-neutral-100 dark:border-neutral-500 dark:hover:bg-neutral-100\">\n          <td class=\"text-left align-text-top p-2 column-class-glico\">\n            and now you’re paying the price, you goddamn idiot.\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-lojbo_gi_e_se_fanva_la_gleki\">\n            .i ca ku do pleji doi bebna co se dapma be lo cevni\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-lojbo_fi_e_se_fanva_la_pimlu\">\n            .i do noi malbebna cu pleji\n          </td>\n        </tr>\n        <tr class=\"border-b transition duration-300 ease-in-out hover:bg-neutral-100 dark:border-neutral-500 dark:hover:bg-neutral-100\">\n          <td class=\"text-left align-text-top p-2 column-class-glico\">\n            I will shit fury all over you and you will drown in it.\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-lojbo_gi_e_se_fanva_la_gleki\">\n            .i pe'a mi ba ku fai le kalci cu jai gau carvi do .i je do jinru ri\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-lojbo_fi_e_se_fanva_la_pimlu\">\n            .i mi ba cavgau lo camfe'u do noi ba jaurvasmro ra\n          </td>\n        </tr>\n        <tr class=\"border-b transition duration-300 ease-in-out hover:bg-neutral-100 dark:border-neutral-500 dark:hover:bg-neutral-100\">\n          <td class=\"text-left align-text-top p-2 column-class-glico\">\n            You’re fucking dead, kiddo.\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-lojbo_gi_e_se_fanva_la_gleki\">\n            .i ke'u ge'e ga'i do mabla morsi\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-lojbo_fi_e_se_fanva_la_pimlu\">\n            .i ke'u do malmro vau ga'i\n          </td>\n        </tr>\n      </tbody>\n    </table></div></div></div>\n  </div>\n</div></div>","fullPath":"/app/src/md_pages/pt/texts/navy-seal-copypasta.md","toc":[],"imgs":[]}},"__N_SSG":true}