{"pageProps":{"post":{"slug":["text","Terrorysta, on patrzy."],"title":"Terrorysta, on patrzy.","hidden":false,"content":"<div class=\"w-full\">\n  <input type=\"checkbox\" id=\"hide-column-po_olska\" class=\"hide-column-checkbox-po_olska\">\n  <label for=\"hide-column-po_olska\" class=\"hide-column-button-po_olska inline-block rounded-l drop-shadow bg-blue-500 hover:bg-blue-600 focus:bg-blue-600 text-white font-bold uppercase leading-normal select-none py-2 px-4\">po'olska</label><input type=\"checkbox\" id=\"hide-column-lojbo\" class=\"hide-column-checkbox-lojbo\">\n  <label for=\"hide-column-lojbo\" class=\"hide-column-button-lojbo inline-block drop-shadow bg-blue-500 hover:bg-blue-600 focus:bg-blue-600 text-white font-bold uppercase leading-normal select-none py-2 px-4\">lojbo</label><input type=\"checkbox\" id=\"hide-column-ponjo\" class=\"hide-column-checkbox-ponjo\">\n  <label for=\"hide-column-ponjo\" class=\"hide-column-button-ponjo inline-block drop-shadow bg-blue-500 hover:bg-blue-600 focus:bg-blue-600 text-white font-bold uppercase leading-normal select-none py-2 px-4\">ponjo</label><input type=\"checkbox\" id=\"hide-column-rusko\" class=\"hide-column-checkbox-rusko\">\n  <label for=\"hide-column-rusko\" class=\"hide-column-button-rusko inline-block rounded-r drop-shadow bg-blue-500 hover:bg-blue-600 focus:bg-blue-600 text-white font-bold uppercase leading-normal select-none py-2 px-4\">rusko</label>\n  <div class=\"md-typeset__scrollwrap\"><div class=\"md-typeset__scrollwrap\"><div class=\"md-typeset__table\"><table class=\"mt-2 table-fixed max-w-full border font-light dark:border-neutral-500 text-left text-sm\">\n    <thead class=\"border-b italic dark:border-neutral-500\">\n      <tr>\n        <th scope=\"col\" class=\"px-6 py-4 column-class-po_olska\">po'olska</th>\n        <th scope=\"col\" class=\"px-6 py-4 column-class-lojbo\">lojbo</th>\n        <th scope=\"col\" class=\"px-6 py-4 column-class-ponjo\">ponjo</th>\n        <th scope=\"col\" class=\"px-6 py-4 column-class-rusko\">rusko</th>\n      </tr>\n    </thead>\n    <tbody>\n      <tr class=\"border-b transition duration-300 ease-in-out hover:bg-neutral-100 dark:border-neutral-500 dark:hover:bg-neutral-600\">\n        <td class=\"font-bold text-left align-text-top px-6 py-4 column-class-po_olska\"></td>\n        <td class=\"font-bold text-left align-text-top px-6 py-4 column-class-lojbo\"></td>\n        <td class=\"font-bold text-left align-text-top px-6 py-4 column-class-ponjo\"></td>\n        <td class=\"font-bold text-left align-text-top px-6 py-4 column-class-rusko\"></td>\n      </tr>\n      <tr class=\"border-b transition duration-300 ease-in-out hover:bg-neutral-100 dark:border-neutral-500 dark:hover:bg-neutral-600\">\n        <td class=\"text-left align-text-top px-6 py-4 column-class-po_olska\"></td>\n        <td class=\"text-left align-text-top px-6 py-4 column-class-lojbo\"></td>\n        <td class=\"text-left align-text-top px-6 py-4 column-class-ponjo\"></td>\n        <td class=\"text-left align-text-top px-6 py-4 column-class-rusko\"></td>\n      </tr>\n      <tr class=\"border-b transition duration-300 ease-in-out hover:bg-neutral-100 dark:border-neutral-500 dark:hover:bg-neutral-600\">\n        <td class=\"text-left align-text-top px-6 py-4 column-class-po_olska\">\n          Szymborska Wisława\n        </td>\n        <td class=\"text-left align-text-top px-6 py-4 column-class-lojbo\">\n          la visuuavas cimborskas\n        </td>\n        <td class=\"text-left align-text-top px-6 py-4 column-class-ponjo\">\n          シンボールスカ・ヴィスワーヴァ\n        </td>\n        <td class=\"text-left align-text-top px-6 py-4 column-class-rusko\">\n          Вислава Шимборска\n        </td>\n      </tr>\n      <tr class=\"border-b transition duration-300 ease-in-out hover:bg-neutral-100 dark:border-neutral-500 dark:hover:bg-neutral-600\">\n        <td class=\"text-left align-text-top px-6 py-4 column-class-po_olska\"></td>\n        <td class=\"text-left align-text-top px-6 py-4 column-class-lojbo\">\n          i la uakci cu fanva\n        </td>\n        <td class=\"text-left align-text-top px-6 py-4 column-class-ponjo\">\n          サトちゃん(uakci)の翻訳\n        </td>\n        <td class=\"text-left align-text-top px-6 py-4 column-class-rusko\">\n          перевёл Андрей Беккер\n        </td>\n      </tr>\n      <tr class=\"border-b transition duration-300 ease-in-out hover:bg-neutral-100 dark:border-neutral-500 dark:hover:bg-neutral-600\">\n        <td class=\"text-left align-text-top px-6 py-4 column-class-po_olska\"></td>\n        <td class=\"text-left align-text-top px-6 py-4 column-class-lojbo\"></td>\n        <td class=\"text-left align-text-top px-6 py-4 column-class-ponjo\"></td>\n        <td class=\"text-left align-text-top px-6 py-4 column-class-rusko\"></td>\n      </tr>\n      <tr class=\"border-b transition duration-300 ease-in-out hover:bg-neutral-100 dark:border-neutral-500 dark:hover:bg-neutral-600\">\n        <td class=\"text-left align-text-top px-6 py-4 column-class-po_olska\">\n          Terrorysta, on patrzy.\n        </td>\n        <td class=\"text-left align-text-top px-6 py-4 column-class-lojbo\">\n          sorxaizu'e sei catlu\n        </td>\n        <td class=\"text-left align-text-top px-6 py-4 column-class-ponjo\">\n          テロリスト、見てる\n        </td>\n        <td class=\"text-left align-text-top px-6 py-4 column-class-rusko\">\n          Террорист, он смотрит.\n        </td>\n      </tr>\n      <tr class=\"border-b transition duration-300 ease-in-out hover:bg-neutral-100 dark:border-neutral-500 dark:hover:bg-neutral-600\">\n        <td class=\"text-left align-text-top px-6 py-4 column-class-po_olska\"></td>\n        <td class=\"text-left align-text-top px-6 py-4 column-class-lojbo\"></td>\n        <td class=\"text-left align-text-top px-6 py-4 column-class-ponjo\"></td>\n        <td class=\"text-left align-text-top px-6 py-4 column-class-rusko\"></td>\n      </tr>\n      <tr class=\"border-b transition duration-300 ease-in-out hover:bg-neutral-100 dark:border-neutral-500 dark:hover:bg-neutral-600\">\n        <td class=\"text-left align-text-top px-6 py-4 column-class-po_olska\">\n          Bomba wybuchnie w barze trzynasta dwadzieścia.\n        </td>\n        <td class=\"text-left align-text-top px-6 py-4 column-class-lojbo\">\n          i lo jbama ku porpi ne'i lo barja ti'u li pa ci pi'e re no\n        </td>\n        <td class=\"text-left align-text-top px-6 py-4 column-class-ponjo\">\n          爆弾は十三時二十分に爆発する。\n        </td>\n        <td class=\"text-left align-text-top px-6 py-4 column-class-rusko\">\n          Бомба рванёт в баре в тринадцать двадцать.\n        </td>\n      </tr>\n      <tr class=\"border-b transition duration-300 ease-in-out hover:bg-neutral-100 dark:border-neutral-500 dark:hover:bg-neutral-600\">\n        <td class=\"text-left align-text-top px-6 py-4 column-class-po_olska\">\n          Teraz mamy dopiero trzynastą szesnaście.\n        </td>\n        <td class=\"text-left align-text-top px-6 py-4 column-class-lojbo\">\n          i nau'u se tcika li po'o pa ci pi'e pa xa\n        </td>\n        <td class=\"text-left align-text-top px-6 py-4 column-class-ponjo\">\n          今は十三時十六分だけ。\n        </td>\n        <td class=\"text-left align-text-top px-6 py-4 column-class-rusko\">\n          Сейчас имеем только тринадцать шестнадцать.\n        </td>\n      </tr>\n      <tr class=\"border-b transition duration-300 ease-in-out hover:bg-neutral-100 dark:border-neutral-500 dark:hover:bg-neutral-600\">\n        <td class=\"text-left align-text-top px-6 py-4 column-class-po_olska\">\n          Niektórzy zdążą jeszcze wejść.\n        </td>\n        <td class=\"text-left align-text-top px-6 py-4 column-class-lojbo\">\n          i so'o da snada lo ka barkla\n        </td>\n        <td class=\"text-left align-text-top px-6 py-4 column-class-ponjo\">\n          人々は遅れずに出るか\n        </td>\n        <td class=\"text-left align-text-top px-6 py-4 column-class-rusko\">\n          Некоторые успеют ещё войти.\n        </td>\n      </tr>\n      <tr class=\"border-b transition duration-300 ease-in-out hover:bg-neutral-100 dark:border-neutral-500 dark:hover:bg-neutral-600\">\n        <td class=\"text-left align-text-top px-6 py-4 column-class-po_olska\">\n          Niektórzy wyjść.\n        </td>\n        <td class=\"text-left align-text-top px-6 py-4 column-class-lojbo\">\n          ja lo ka nerkla\n        </td>\n        <td class=\"text-left align-text-top px-6 py-4 column-class-ponjo\">\n          入るか。\n        </td>\n        <td class=\"text-left align-text-top px-6 py-4 column-class-rusko\">\n          Некоторые выйти.\n        </td>\n      </tr>\n      <tr class=\"border-b transition duration-300 ease-in-out hover:bg-neutral-100 dark:border-neutral-500 dark:hover:bg-neutral-600\">\n        <td class=\"text-left align-text-top px-6 py-4 column-class-po_olska\"></td>\n        <td class=\"text-left align-text-top px-6 py-4 column-class-lojbo\"></td>\n        <td class=\"text-left align-text-top px-6 py-4 column-class-ponjo\"></td>\n        <td class=\"text-left align-text-top px-6 py-4 column-class-rusko\"></td>\n      </tr>\n      <tr class=\"border-b transition duration-300 ease-in-out hover:bg-neutral-100 dark:border-neutral-500 dark:hover:bg-neutral-600\">\n        <td class=\"text-left align-text-top px-6 py-4 column-class-po_olska\">\n          Terrorysta już przeszedł na drugą stronę ulicy.\n        </td>\n        <td class=\"text-left align-text-top px-6 py-4 column-class-lojbo\">\n          i lo sorxaizu'e ba'o ragvybi'o lo klaji\n        </td>\n        <td class=\"text-left align-text-top px-6 py-4 column-class-ponjo\">\n          テロリストはもう道の向こうに行った。\n        </td>\n        <td class=\"text-left align-text-top px-6 py-4 column-class-rusko\">\n          Террорист уже перешёл на другую сторону улицы.\n        </td>\n      </tr>\n      <tr class=\"border-b transition duration-300 ease-in-out hover:bg-neutral-100 dark:border-neutral-500 dark:hover:bg-neutral-600\">\n        <td class=\"text-left align-text-top px-6 py-4 column-class-po_olska\">\n          Ta odległość go chroni od wszelkiego złego\n        </td>\n        <td class=\"text-left align-text-top px-6 py-4 column-class-lojbo\">\n          i darno raunzu fi lo ka snura\n        </td>\n        <td class=\"text-left align-text-top px-6 py-4 column-class-ponjo\">\n          遠くてどの危険も感じれず\n        </td>\n        <td class=\"text-left align-text-top px-6 py-4 column-class-rusko\">\n          Эта удалённость его хранит от всяких бед,\n        </td>\n      </tr>\n      <tr class=\"border-b transition duration-300 ease-in-out hover:bg-neutral-100 dark:border-neutral-500 dark:hover:bg-neutral-600\">\n        <td class=\"text-left align-text-top px-6 py-4 column-class-po_olska\">\n          no i widok jak w kinie:\n        </td>\n        <td class=\"text-left align-text-top px-6 py-4 column-class-lojbo\">\n          je ja'a zgana tai lo skina\n        </td>\n        <td class=\"text-left align-text-top px-6 py-4 column-class-ponjo\">\n          映画のような見解。\n        </td>\n        <td class=\"text-left align-text-top px-6 py-4 column-class-rusko\">\n          ну и вид, как в кино:\n        </td>\n      </tr>\n      <tr class=\"border-b transition duration-300 ease-in-out hover:bg-neutral-100 dark:border-neutral-500 dark:hover:bg-neutral-600\">\n        <td class=\"text-left align-text-top px-6 py-4 column-class-po_olska\"></td>\n        <td class=\"text-left align-text-top px-6 py-4 column-class-lojbo\"></td>\n        <td class=\"text-left align-text-top px-6 py-4 column-class-ponjo\"></td>\n        <td class=\"text-left align-text-top px-6 py-4 column-class-rusko\"></td>\n      </tr>\n      <tr class=\"border-b transition duration-300 ease-in-out hover:bg-neutral-100 dark:border-neutral-500 dark:hover:bg-neutral-600\">\n        <td class=\"text-left align-text-top px-6 py-4 column-class-po_olska\">\n          Kobieta w żółtej kurtce, ona wchodzi.\n        </td>\n        <td class=\"text-left align-text-top px-6 py-4 column-class-lojbo\">\n          i ninmu je dasni be lo pelxu sei nerkla\n        </td>\n        <td class=\"text-left align-text-top px-6 py-4 column-class-ponjo\">\n          黄色いコートの女性、入る。\n        </td>\n        <td class=\"text-left align-text-top px-6 py-4 column-class-rusko\">\n          Женщина в жёлтой куртке, она входит.\n        </td>\n      </tr>\n      <tr class=\"border-b transition duration-300 ease-in-out hover:bg-neutral-100 dark:border-neutral-500 dark:hover:bg-neutral-600\">\n        <td class=\"text-left align-text-top px-6 py-4 column-class-po_olska\">\n          Mężczyzna w ciemnych okularach, on wychodzi.\n        </td>\n        <td class=\"text-left align-text-top px-6 py-4 column-class-lojbo\">\n          i nanmu je xekri se lenjo sei barkla\n        </td>\n        <td class=\"text-left align-text-top px-6 py-4 column-class-ponjo\">\n          暗いメガネの男性、出る。\n        </td>\n        <td class=\"text-left align-text-top px-6 py-4 column-class-rusko\">\n          Мужчина в тёмных очках, он выходит.\n        </td>\n      </tr>\n      <tr class=\"border-b transition duration-300 ease-in-out hover:bg-neutral-100 dark:border-neutral-500 dark:hover:bg-neutral-600\">\n        <td class=\"text-left align-text-top px-6 py-4 column-class-po_olska\">\n          Chłopaki w dżinsach, oni rozmawiają.\n        </td>\n        <td class=\"text-left align-text-top px-6 py-4 column-class-lojbo\">\n          i nanla je ke blanu palku dasni sei tavla\n        </td>\n        <td class=\"text-left align-text-top px-6 py-4 column-class-ponjo\">\n          ジーンズの男たち、喋ってる。\n        </td>\n        <td class=\"text-left align-text-top px-6 py-4 column-class-rusko\">\n          Парни в джинсах, они разговаривают.\n        </td>\n      </tr>\n      <tr class=\"border-b transition duration-300 ease-in-out hover:bg-neutral-100 dark:border-neutral-500 dark:hover:bg-neutral-600\">\n        <td class=\"text-left align-text-top px-6 py-4 column-class-po_olska\">\n          Trzynasta siedemnaście i cztery sekundy.\n        </td>\n        <td class=\"text-left align-text-top px-6 py-4 column-class-lojbo\">\n          i pa ci pi'e pa ze pi'e vo\n        </td>\n        <td class=\"text-left align-text-top px-6 py-4 column-class-ponjo\">\n          十三時十七分四秒。\n        </td>\n        <td class=\"text-left align-text-top px-6 py-4 column-class-rusko\">\n          Тринадцать семнадцать и четыре секунды.\n        </td>\n      </tr>\n      <tr class=\"border-b transition duration-300 ease-in-out hover:bg-neutral-100 dark:border-neutral-500 dark:hover:bg-neutral-600\">\n        <td class=\"text-left align-text-top px-6 py-4 column-class-po_olska\">\n          Ten niższy to ma szczęście i wsiada na skuter,\n        </td>\n        <td class=\"text-left align-text-top px-6 py-4 column-class-lojbo\">\n          i lo cmalu ku se zanfu'a lo ka cpana lo marce\n        </td>\n        <td class=\"text-left align-text-top px-6 py-4 column-class-ponjo\">\n          低いのが運よくバイクを乗る\n        </td>\n        <td class=\"text-left align-text-top px-6 py-4 column-class-rusko\">\n          Этому низенькому везёт, он садится на скутер,\n        </td>\n      </tr>\n      <tr class=\"border-b transition duration-300 ease-in-out hover:bg-neutral-100 dark:border-neutral-500 dark:hover:bg-neutral-600\">\n        <td class=\"text-left align-text-top px-6 py-4 column-class-po_olska\">\n          a ten wyższy to wchodzi.\n        </td>\n        <td class=\"text-left align-text-top px-6 py-4 column-class-lojbo\">\n          i lo barda ku nerkla\n        </td>\n        <td class=\"text-left align-text-top px-6 py-4 column-class-ponjo\">\n          が高いのが入る。\n        </td>\n        <td class=\"text-left align-text-top px-6 py-4 column-class-rusko\">\n          а этот повыше, он входит.\n        </td>\n      </tr>\n      <tr class=\"border-b transition duration-300 ease-in-out hover:bg-neutral-100 dark:border-neutral-500 dark:hover:bg-neutral-600\">\n        <td class=\"text-left align-text-top px-6 py-4 column-class-po_olska\"></td>\n        <td class=\"text-left align-text-top px-6 py-4 column-class-lojbo\"></td>\n        <td class=\"text-left align-text-top px-6 py-4 column-class-ponjo\"></td>\n        <td class=\"text-left align-text-top px-6 py-4 column-class-rusko\"></td>\n      </tr>\n      <tr class=\"border-b transition duration-300 ease-in-out hover:bg-neutral-100 dark:border-neutral-500 dark:hover:bg-neutral-600\">\n        <td class=\"text-left align-text-top px-6 py-4 column-class-po_olska\">\n          Trzynasta siedemnaście i czterdzieści sekund.\n        </td>\n        <td class=\"text-left align-text-top px-6 py-4 column-class-lojbo\">\n          i pa ci pi'e pa ze pi'e vo no\n        </td>\n        <td class=\"text-left align-text-top px-6 py-4 column-class-ponjo\">\n          十三時十七分四十秒。\n        </td>\n        <td class=\"text-left align-text-top px-6 py-4 column-class-rusko\">\n          Тринадцать семнадцать и сорок секунд.\n        </td>\n      </tr>\n      <tr class=\"border-b transition duration-300 ease-in-out hover:bg-neutral-100 dark:border-neutral-500 dark:hover:bg-neutral-600\">\n        <td class=\"text-left align-text-top px-6 py-4 column-class-po_olska\">\n          Dziewczyna, ona idzie z zieloną wstążką we włosach.\n        </td>\n        <td class=\"text-left align-text-top px-6 py-4 column-class-lojbo\">\n          i nixli je se jadni be lo crino djine sei cadzu\n        </td>\n        <td class=\"text-left align-text-top px-6 py-4 column-class-ponjo\">\n          女、髪にの緑のリボンのが歩いてる。\n        </td>\n        <td class=\"text-left align-text-top px-6 py-4 column-class-rusko\">\n          Девушка, она идёт с зелёной тесьмой в волосах.\n        </td>\n      </tr>\n      <tr class=\"border-b transition duration-300 ease-in-out hover:bg-neutral-100 dark:border-neutral-500 dark:hover:bg-neutral-600\">\n        <td class=\"text-left align-text-top px-6 py-4 column-class-po_olska\">\n          Tylko że ten autobus nagle ją zasłania.\n        </td>\n        <td class=\"text-left align-text-top px-6 py-4 column-class-lojbo\">\n          i ku'i lo sorprekarce ze'i jai ri'a zilmipri\n        </td>\n        <td class=\"text-left align-text-top px-6 py-4 column-class-ponjo\">\n          がバスは突然に覆う。\n        </td>\n        <td class=\"text-left align-text-top px-6 py-4 column-class-rusko\">\n          Да только вот автобус вдруг её заслоняет.\n        </td>\n      </tr>\n      <tr class=\"border-b transition duration-300 ease-in-out hover:bg-neutral-100 dark:border-neutral-500 dark:hover:bg-neutral-600\">\n        <td class=\"text-left align-text-top px-6 py-4 column-class-po_olska\"></td>\n        <td class=\"text-left align-text-top px-6 py-4 column-class-lojbo\"></td>\n        <td class=\"text-left align-text-top px-6 py-4 column-class-ponjo\"></td>\n        <td class=\"text-left align-text-top px-6 py-4 column-class-rusko\"></td>\n      </tr>\n      <tr class=\"border-b transition duration-300 ease-in-out hover:bg-neutral-100 dark:border-neutral-500 dark:hover:bg-neutral-600\">\n        <td class=\"text-left align-text-top px-6 py-4 column-class-po_olska\">\n          Trzynasta osiemnaście.\n        </td>\n        <td class=\"text-left align-text-top px-6 py-4 column-class-lojbo\">\n          i pa ci pi'e pa bi\n        </td>\n        <td class=\"text-left align-text-top px-6 py-4 column-class-ponjo\">\n          十三時十八分。\n        </td>\n        <td class=\"text-left align-text-top px-6 py-4 column-class-rusko\">\n          Тринадцать восемнадцать.\n        </td>\n      </tr>\n      <tr class=\"border-b transition duration-300 ease-in-out hover:bg-neutral-100 dark:border-neutral-500 dark:hover:bg-neutral-600\">\n        <td class=\"text-left align-text-top px-6 py-4 column-class-po_olska\">\n          Już nie ma dziewczyny.\n        </td>\n        <td class=\"text-left align-text-top px-6 py-4 column-class-lojbo\">\n          i lo nixli xa'o canci\n        </td>\n        <td class=\"text-left align-text-top px-6 py-4 column-class-ponjo\">\n          女が今いない。\n        </td>\n        <td class=\"text-left align-text-top px-6 py-4 column-class-rusko\">\n          Уже нет девушки.\n        </td>\n      </tr>\n      <tr class=\"border-b transition duration-300 ease-in-out hover:bg-neutral-100 dark:border-neutral-500 dark:hover:bg-neutral-600\">\n        <td class=\"text-left align-text-top px-6 py-4 column-class-po_olska\">\n          Czy była taka głupia i weszła, czy nie,\n        </td>\n        <td class=\"text-left align-text-top px-6 py-4 column-class-lojbo\">\n          i xau'a bebna lo ka nerkla\n        </td>\n        <td class=\"text-left align-text-top px-6 py-4 column-class-ponjo\">\n          馬鹿だから入るかどうかは\n        </td>\n        <td class=\"text-left align-text-top px-6 py-4 column-class-rusko\">\n          Была такой глупой, что вошла, или нет,\n        </td>\n      </tr>\n      <tr class=\"border-b transition duration-300 ease-in-out hover:bg-neutral-100 dark:border-neutral-500 dark:hover:bg-neutral-600\">\n        <td class=\"text-left align-text-top px-6 py-4 column-class-po_olska\">\n          to sie zobaczy, jak będą wynosić.\n        </td>\n        <td class=\"text-left align-text-top px-6 py-4 column-class-lojbo\">\n          ku vau se facki ca lo nu bargau\n        </td>\n        <td class=\"text-left align-text-top px-6 py-4 column-class-ponjo\">\n          出すときに知る。\n        </td>\n        <td class=\"text-left align-text-top px-6 py-4 column-class-rusko\">\n          он увидит, когда будут выносить.\n        </td>\n      </tr>\n      <tr class=\"border-b transition duration-300 ease-in-out hover:bg-neutral-100 dark:border-neutral-500 dark:hover:bg-neutral-600\">\n        <td class=\"text-left align-text-top px-6 py-4 column-class-po_olska\"></td>\n        <td class=\"text-left align-text-top px-6 py-4 column-class-lojbo\"></td>\n        <td class=\"text-left align-text-top px-6 py-4 column-class-ponjo\"></td>\n        <td class=\"text-left align-text-top px-6 py-4 column-class-rusko\"></td>\n      </tr>\n      <tr class=\"border-b transition duration-300 ease-in-out hover:bg-neutral-100 dark:border-neutral-500 dark:hover:bg-neutral-600\">\n        <td class=\"text-left align-text-top px-6 py-4 column-class-po_olska\">\n          Trzynasta dziewiętnaście.\n        </td>\n        <td class=\"text-left align-text-top px-6 py-4 column-class-lojbo\">\n          i pa ci pi'e pa so\n        </td>\n        <td class=\"text-left align-text-top px-6 py-4 column-class-ponjo\">\n          十三時十九分。\n        </td>\n        <td class=\"text-left align-text-top px-6 py-4 column-class-rusko\">\n          Тринадцать девятнадцать.\n        </td>\n      </tr>\n      <tr class=\"border-b transition duration-300 ease-in-out hover:bg-neutral-100 dark:border-neutral-500 dark:hover:bg-neutral-600\">\n        <td class=\"text-left align-text-top px-6 py-4 column-class-po_olska\">\n          Nikt jakoś nie wchodzi.\n        </td>\n        <td class=\"text-left align-text-top px-6 py-4 column-class-lojbo\">\n          i ki'u su'o da no da nerkla\n        </td>\n        <td class=\"text-left align-text-top px-6 py-4 column-class-ponjo\">\n          なんかで誰も入らない。\n        </td>\n        <td class=\"text-left align-text-top px-6 py-4 column-class-rusko\">\n          Никто как-то не входит.\n        </td>\n      </tr>\n      <tr class=\"border-b transition duration-300 ease-in-out hover:bg-neutral-100 dark:border-neutral-500 dark:hover:bg-neutral-600\">\n        <td class=\"text-left align-text-top px-6 py-4 column-class-po_olska\">\n          Za to jeszcze wychodzi jeden gruby łysy.\n        </td>\n        <td class=\"text-left align-text-top px-6 py-4 column-class-lojbo\">\n          i ku'i pa sedykrecau ku barkla\n        </td>\n        <td class=\"text-left align-text-top px-6 py-4 column-class-ponjo\">\n          が禿げた太い一人が出る。\n        </td>\n        <td class=\"text-left align-text-top px-6 py-4 column-class-rusko\">\n          Зато ещё выходит один здоровый лысый.\n        </td>\n      </tr>\n      <tr class=\"border-b transition duration-300 ease-in-out hover:bg-neutral-100 dark:border-neutral-500 dark:hover:bg-neutral-600\">\n        <td class=\"text-left align-text-top px-6 py-4 column-class-po_olska\">\n          Ale tak, jakby szukał czegoś po kieszeniach i\n        </td>\n        <td class=\"text-left align-text-top px-6 py-4 column-class-lojbo\">\n          i ku'i simlu lo ka sisku tu'a lo daski\n        </td>\n        <td class=\"text-left align-text-top px-6 py-4 column-class-ponjo\">\n          けどポケットに何かを探すのように\n        </td>\n        <td class=\"text-left align-text-top px-6 py-4 column-class-rusko\">\n          Но чего-то шарит по карманам и\n        </td>\n      </tr>\n      <tr class=\"border-b transition duration-300 ease-in-out hover:bg-neutral-100 dark:border-neutral-500 dark:hover:bg-neutral-600\">\n        <td class=\"text-left align-text-top px-6 py-4 column-class-po_olska\">\n          o trzynastej dwadzieścia bez dziesięciu sekund\n        </td>\n        <td class=\"text-left align-text-top px-6 py-4 column-class-lojbo\">\n          kei ja'e lo nu ti'u li pa ci pi'e re no vu'u pi'e pi'e dau\n        </td>\n        <td class=\"text-left align-text-top px-6 py-4 column-class-ponjo\">\n          十秒無しでの十三時二十分に\n        </td>\n        <td class=\"text-left align-text-top px-6 py-4 column-class-rusko\">\n          в тринадцать двадцать без десяти секунд\n        </td>\n      </tr>\n      <tr class=\"border-b transition duration-300 ease-in-out hover:bg-neutral-100 dark:border-neutral-500 dark:hover:bg-neutral-600\">\n        <td class=\"text-left align-text-top px-6 py-4 column-class-po_olska\">\n          wraca po te swoje marne rękawiczki.\n        </td>\n        <td class=\"text-left align-text-top px-6 py-4 column-class-lojbo\">\n          tolcliva te zu'e tu'a lo nalvai gluta\n        </td>\n        <td class=\"text-left align-text-top px-6 py-4 column-class-ponjo\">\n          その悲惨なグローブの為に帰る。\n        </td>\n        <td class=\"text-left align-text-top px-6 py-4 column-class-rusko\">\n          возвращается за своими паршивыми перчатками.\n        </td>\n      </tr>\n      <tr class=\"border-b transition duration-300 ease-in-out hover:bg-neutral-100 dark:border-neutral-500 dark:hover:bg-neutral-600\">\n        <td class=\"text-left align-text-top px-6 py-4 column-class-po_olska\"></td>\n        <td class=\"text-left align-text-top px-6 py-4 column-class-lojbo\"></td>\n        <td class=\"text-left align-text-top px-6 py-4 column-class-ponjo\"></td>\n        <td class=\"text-left align-text-top px-6 py-4 column-class-rusko\"></td>\n      </tr>\n      <tr class=\"border-b transition duration-300 ease-in-out hover:bg-neutral-100 dark:border-neutral-500 dark:hover:bg-neutral-600\">\n        <td class=\"text-left align-text-top px-6 py-4 column-class-po_olska\">\n          Jest trzynasta dwadzieścia.\n        </td>\n        <td class=\"text-left align-text-top px-6 py-4 column-class-lojbo\">\n          i pa ci pi'e re no je'u\n        </td>\n        <td class=\"text-left align-text-top px-6 py-4 column-class-ponjo\">\n          もう十三時二十分。\n        </td>\n        <td class=\"text-left align-text-top px-6 py-4 column-class-rusko\">\n          Вот тринадцать двадцать.\n        </td>\n      </tr>\n      <tr class=\"border-b transition duration-300 ease-in-out hover:bg-neutral-100 dark:border-neutral-500 dark:hover:bg-neutral-600\">\n        <td class=\"text-left align-text-top px-6 py-4 column-class-po_olska\">\n          Czas, jak on się wlecze.\n        </td>\n        <td class=\"text-left align-text-top px-6 py-4 column-class-lojbo\">\n          i lo tcika zo'u masno\n        </td>\n        <td class=\"text-left align-text-top px-6 py-4 column-class-ponjo\">\n          時は早くない流れてるの。\n        </td>\n        <td class=\"text-left align-text-top px-6 py-4 column-class-rusko\">\n          Время, как же оно тащится.\n        </td>\n      </tr>\n      <tr class=\"border-b transition duration-300 ease-in-out hover:bg-neutral-100 dark:border-neutral-500 dark:hover:bg-neutral-600\">\n        <td class=\"text-left align-text-top px-6 py-4 column-class-po_olska\">\n          Już chyba teraz.\n        </td>\n        <td class=\"text-left align-text-top px-6 py-4 column-class-lojbo\">\n          i ju'o cu'i ca\n        </td>\n        <td class=\"text-left align-text-top px-6 py-4 column-class-ponjo\">\n          今だろう。\n        </td>\n        <td class=\"text-left align-text-top px-6 py-4 column-class-rusko\">\n          Ну вроде сейчас.\n        </td>\n      </tr>\n      <tr class=\"border-b transition duration-300 ease-in-out hover:bg-neutral-100 dark:border-neutral-500 dark:hover:bg-neutral-600\">\n        <td class=\"text-left align-text-top px-6 py-4 column-class-po_olska\">\n          Jeszcze nie teraz.\n        </td>\n        <td class=\"text-left align-text-top px-6 py-4 column-class-lojbo\">\n          i ca pu'o\n        </td>\n        <td class=\"text-left align-text-top px-6 py-4 column-class-ponjo\">\n          まだ今よ。\n        </td>\n        <td class=\"text-left align-text-top px-6 py-4 column-class-rusko\">\n          Ещё не сейчас.\n        </td>\n      </tr>\n      <tr class=\"border-b transition duration-300 ease-in-out hover:bg-neutral-100 dark:border-neutral-500 dark:hover:bg-neutral-600\">\n        <td class=\"text-left align-text-top px-6 py-4 column-class-po_olska\">\n          Tak, teraz.\n        </td>\n        <td class=\"text-left align-text-top px-6 py-4 column-class-lojbo\">\n          i ca ja'a\n        </td>\n        <td class=\"text-left align-text-top px-6 py-4 column-class-ponjo\">\n          はい、今。\n        </td>\n        <td class=\"text-left align-text-top px-6 py-4 column-class-rusko\">\n          Так, сейчас.\n        </td>\n      </tr>\n      <tr class=\"border-b transition duration-300 ease-in-out hover:bg-neutral-100 dark:border-neutral-500 dark:hover:bg-neutral-600\">\n        <td class=\"text-left align-text-top px-6 py-4 column-class-po_olska\">\n          Bomba, ona wybucha.\n        </td>\n        <td class=\"text-left align-text-top px-6 py-4 column-class-lojbo\">\n          i jbama sei porpi\n        </td>\n        <td class=\"text-left align-text-top px-6 py-4 column-class-ponjo\">\n          爆弾、爆発してる。\n        </td>\n        <td class=\"text-left align-text-top px-6 py-4 column-class-rusko\">\n          Бомба, она взрывается.\n        </td>\n      </tr>\n    </tbody>\n  </table></div></div></div>\n</div>","fullPath":"/app/src/md_pages/text/Terrorysta, on patrzy..md","toc":[],"imgs":[]}},"__N_SSG":true}