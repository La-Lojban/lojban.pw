,"a-terrorist-he-is-watching"],"hidden":false,"title":"A terrorist, he is watching","directory":"texts"},{"slug":["texts","alice-in-wonderland"],"hidden":false,"title":"Alice in Wonderland","directory":"texts"},{"slug":["texts","how-the-enemy-came-to-thlunrana"],"hidden":false,"title":"How the enemy came to Thlunrana","directory":"texts"},{"slug":["texts","in-a-bitter-hour"],"hidden":false,"title":"In A Bitter Hour","directory":"texts"},{"slug":["texts","jokes"],"hidden":false,"title":"Jokes","directory":"texts"},{"slug":["texts","lords-prayer"],"hidden":false,"title":"Lord's prayer","directory":"texts"},{"slug":["texts","navy-seal-copypasta"],"hidden":false,"title":"Navy Seal Copypasta","directory":"texts"},{"slug":["texts","terry-the-tiger-visits-the-big-city"],"hidden":false,"title":"Terry the Tiger Visits the Big City","directory":"texts"},{"slug":["texts","the-bad-beginning"],"hidden":false,"title":"The Bad Beginning","directory":"texts"},{"slug":["texts","the-book"],"hidden":false,"title":"The Book","directory":"texts"},{"slug":["texts","the-girl-from-ipanema"],"hidden":false,"title":"The Girl from Ipanema","directory":"texts"},{"slug":["texts","the-mask"],"hidden":false,"title":"The Mask","directory":"texts"},{"slug":["texts","the-north-wind-and-the-sun"],"hidden":false,"title":"The North Wind and the Sun","directory":"texts"},{"slug":["texts","there-will-come-soft-rains"],"hidden":false,"title":"There Will Come Soft Rains","directory":"texts"},{"slug":["texts","to-kill-a-child"],"hidden":false,"title":"To Kill a Child","directory":"texts"}],"currentLanguage":"ru","post":{"slug":["ru","welcome"],"hidden":false,"meta.title":"Изучите Ложбан","content":"<p><strong>Ложбан</strong> - это говоримый логический язык, созданный в 1987 году и теперь поддерживаемый его носителями.</p>\n<p>Вот бесплатные для использования, неофициальные, свободные учебники и документация по языку Ложбан.</p>\n<p>Вы можете отправлять любые предложения на <a href=\"mailto:gleki.is.my.name@gmail.com\">gleki.is.my.name@gmail.com</a> или добавлять проблемы в <a href=\"https://github.com/la-lojban/lojban-made-easy/issues\">репозиторий исходного кода Ложбан</a>.</p>\n<h2 id=\"курс-изучаем-ложбан\"><a href=\"/ru/books/learn-lojban\">Курс \"Изучаем ложбан\"</a><a class=\"print:hidden\" aria-hidden=\"true\" tabindex=\"-1\" href=\"#курс-изучаем-ложбан\"><span class=\"in-heading hash\">#</span></a></h2>\n<p>Этот курс обучает Ложбану с его формальными основами, но простыми терминами и множеством примеров использования.</p>\n<ul>\n<li><a href=\"/vreji/uencu/learn-lojban.pdf\">PDF</a> - в файле PDF для загрузки.</li>\n</ul>\n<h2 id=\"чат-ложбана-в-реальном-времени-в-мессенджере-discord\"><a href=\"https://discord.gg/wasp5fj\">Чат ложбана в реальном времени</a> в мессенджере Discord<a class=\"print:hidden\" aria-hidden=\"true\" tabindex=\"-1\" href=\"#чат-ложбана-в-реальном-времени-в-мессенджере-discord\"><span class=\"in-heading hash\">#</span></a></h2>\n<h2 id=\"неофициальная-книга-полный-язык-ложбан-издание-октябрь-2022-года\">Неофициальная книга \"Полный язык Ложбан\", издание октябрь 2022 года<a class=\"print:hidden\" aria-hidden=\"true\" tabindex=\"-1\" href=\"#неофициальная-книга-полный-язык-ложбан-издание-октябрь-2022-года\"><span class=\"in-heading hash\">#</span></a></h2>\n<p>Эта книга придерживается оригинальной книги, опубликованной в 1997 году, и:</p>\n<ul>\n<li>Исправляет ошибки</li>\n<li>Исправляет противоречия</li>\n<li>Добавляет новый контент, который не нарушает предыдущий контент</li>\n</ul>\n<p>Она доступна в следующих форматах:</p>\n<ul>\n<li><a href=\"https://la-lojban.github.io/uncll/uncll-1.2.15/cll.pdf\">PDF</a> - в файле PDF для загрузки</li>\n<li><a href=\"https://la-lojban.github.io/uncll/uncll-1.2.15/xhtml_section_chunks/\">HTML в разделах</a> - в HTML-файлах</li>\n</ul>\n\n<p><a href=\"/ru/articles/complete-lojban-language\">Больше информации...</a></p>\n<h2 id=\"-la-sutysisku---элегантный-неофициальный-словарь\"><img src=\"https://la-lojban.github.io/sutysisku/pixra/snime.svg\" alt=\"\"> la sutysisku - элегантный неофициальный словарь<a class=\"print:hidden\" aria-hidden=\"true\" tabindex=\"-1\" href=\"#-la-sutysisku---элегантный-неофициальный-словарь\"><span class=\"in-heading hash\">#</span></a></h2>\n<p>Исследуйте <a href=\"https://la-lojban.github.io/sutysisku/en/#seskari=cnano&#x26;sisku=coi_munje\">La Sutysisku</a>, словарь для Ложбана, который включает:</p>\n<ul>\n<li>Фактически стандартные определения слов</li>\n<li>Экспериментальные определения и примеры использования</li>\n</ul>\n<h2 id=\"лицензия\">Лицензия<a class=\"print:hidden\" aria-hidden=\"true\" tabindex=\"-1\" href=\"#лицензия\"><span class=\"in-heading hash\">#</span></a></h2>\n<p>Лицензия на книгу \"Полный язык ложбан\" (довольно мягкая) указана в самой книге.</p>\n<p xmlns:dct=\"https://purl.org/dc/terms/\">\n<a rel=\"license\" href=\"http://creativecommons.org/publicdomain/mark/1.0/\">\n<img src=\"https://i.creativecommons.org/p/mark/1.0/88x31.png\" style=\"border-style: none;\" alt=\"Public Domain Mark\">\n</a>\n<br>\nЭта работа (<span property=\"dct:title\">Изучаем ложбан</span>, автора <a href=\"https://lojban.pw\" rel=\"dct:creator\"><span property=\"dct:title\">Gleki Arxokuna</span></a>), идентифицируемый как <a href=\"https://lojban.pw\" rel=\"dct:publisher\"><span property=\"dct:title\">Gleki Arxokuna</span></a>, не имеет известных ограничений авторских прав.\n</p>","fullPath":"/app/src/md_pages/ru/welcome.md","toc":[{"depth":"2","value":"Курс \"Изучаем ложбан\"","id":"курс-изучаем-ложбан","tagName":"h2"},{"depth":"2","value":"Чат ложбана в реальном времени в мессенджере Discord","id":"чат-ложбана-в-реальном-времени-в-мессенджере-discord","tagName":"h2"},{"depth":"2","value":"Неофициальная книга \"Полный язык Ложбан\", издание октябрь 2022 года","id":"неофициальная-книга-полный-язык-ложбан-издание-октябрь-2022-года","tagName":"h2"},{"depth":"2","value":" la sutysisku - элегантный неофициальный словарь","id":"-la-sutysisku---элегантный-неофициальный-словарь","tagName":"h2"},{"depth":"2","value":"Лицензия","id":"лицензия","tagName":"h2"}],"imgs":[]}},"__N_SSG":true}