,"a-terrorist-he-is-watching"],"hidden":false,"title":"A terrorist, he is watching","directory":"texts"},{"slug":["texts","alice-in-wonderland"],"hidden":false,"title":"Alice in Wonderland","directory":"texts"},{"slug":["texts","how-the-enemy-came-to-thlunrana"],"hidden":false,"title":"How the enemy came to Thlunrana","directory":"texts"},{"slug":["texts","in-a-bitter-hour"],"hidden":false,"title":"In A Bitter Hour","directory":"texts"},{"slug":["texts","jokes"],"hidden":false,"title":"Jokes","directory":"texts"},{"slug":["texts","lords-prayer"],"hidden":false,"title":"Lord's prayer","directory":"texts"},{"slug":["texts","navy-seal-copypasta"],"hidden":false,"title":"Navy Seal Copypasta","directory":"texts"},{"slug":["texts","terry-the-tiger-visits-the-big-city"],"hidden":false,"title":"Terry the Tiger Visits the Big City","directory":"texts"},{"slug":["texts","the-bad-beginning"],"hidden":false,"title":"The Bad Beginning","directory":"texts"},{"slug":["texts","the-book"],"hidden":false,"title":"The Book","directory":"texts"},{"slug":["texts","the-girl-from-ipanema"],"hidden":false,"title":"The Girl from Ipanema","directory":"texts"},{"slug":["texts","the-mask"],"hidden":false,"title":"The Mask","directory":"texts"},{"slug":["texts","the-north-wind-and-the-sun"],"hidden":false,"title":"The North Wind and the Sun","directory":"texts"},{"slug":["texts","there-will-come-soft-rains"],"hidden":false,"title":"There Will Come Soft Rains","directory":"texts"},{"slug":["texts","to-kill-a-child"],"hidden":false,"title":"To Kill a Child","directory":"texts"}],"currentLanguage":"welcome","post":{"slug":["welcome"],"hidden":false,"meta.title":"Learn Lojban","content":"<p><strong>Lojban</strong> is a spoken logical language that was created in 1987 and is now supported by its speakers.</p>\n<p>Here are copyright-free, unofficial, libre tutorials and documentation on the Lojban language.</p>\n<p>You can send any suggestions to <a href=\"mailto:gleki.is.my.name@gmail.com\">gleki.is.my.name@gmail.com</a> or add issues at the <a href=\"https://github.com/la-lojban/lojban-made-easy/issues\">Lojban source repository</a>.</p>\n<h2 id=\"learn-lojban-course\"><a href=\"/books/learn-lojban\">‘Learn Lojban’ course</a><a class=\"print:hidden\" aria-hidden=\"true\" tabindex=\"-1\" href=\"#learn-lojban-course\"><span class=\"in-heading hash\">#</span></a></h2>\n<p>This course teaches Lojban from its formal foundations, but in simple terms and with plenty of usage examples.</p>\n<ul>\n<li><a href=\"/vreji/uencu/learn-lojban.pdf\">PDF</a> - in a PDF file for download.</li>\n</ul>\n<h2 id=\"live-lojban-chat-in-the-discord-messenger\"><a href=\"https://discord.gg/wasp5fj\">Live Lojban chat</a> in the Discord messenger<a class=\"print:hidden\" aria-hidden=\"true\" tabindex=\"-1\" href=\"#live-lojban-chat-in-the-discord-messenger\"><span class=\"in-heading hash\">#</span></a></h2>\n<h2 id=\"unofficial-complete-lojban-language-book-october-2022-edition\">Unofficial ‘Complete Lojban Language’ Book, October 2022 Edition<a class=\"print:hidden\" aria-hidden=\"true\" tabindex=\"-1\" href=\"#unofficial-complete-lojban-language-book-october-2022-edition\"><span class=\"in-heading hash\">#</span></a></h2>\n<p>This book adheres to the original book published in 1997 and:</p>\n<ul>\n<li>Fixes mistypes</li>\n<li>Fixes contradictions</li>\n<li>Adds new content that does not violate previous content</li>\n</ul>\n<p>It is available in the following formats:</p>\n<ul>\n<li><a href=\"https://la-lojban.github.io/uncll/uncll-1.2.15/cll.pdf\">PDF</a> - in a PDF file for download</li>\n<li><a href=\"https://la-lojban.github.io/uncll/uncll-1.2.15/xhtml_section_chunks/\">HTML in sections</a> - in HTML files</li>\n</ul>\n\n<p><a href=\"/articles/complete-lojban-language\">More info...</a></p>\n<h2 id=\"-la-sutysisku---a-slick-unofficial-dictionary\"><img src=\"https://la-lojban.github.io/sutysisku/pixra/snime.svg\" alt=\"\"> la sutysisku - a slick unofficial dictionary<a class=\"print:hidden\" aria-hidden=\"true\" tabindex=\"-1\" href=\"#-la-sutysisku---a-slick-unofficial-dictionary\"><span class=\"in-heading hash\">#</span></a></h2>\n<p>Explore <a href=\"https://la-lojban.github.io/sutysisku/en/#seskari=cnano&#x26;sisku=coi_munje\">La Sutysisku</a>, a dictionary for Lojban that includes:</p>\n<ul>\n<li>De facto standard definitions of words</li>\n<li>Experimental definitions and usage examples</li>\n</ul>\n<h2 id=\"license\">License<a class=\"print:hidden\" aria-hidden=\"true\" tabindex=\"-1\" href=\"#license\"><span class=\"in-heading hash\">#</span></a></h2>\n<p>The license for the ‘Complete Lojban Language’ book (a rather permissive one) is specified in the book itself.</p>\n<p xmlns:dct=\"https://purl.org/dc/terms/\">\n<a rel=\"license\" href=\"http://creativecommons.org/publicdomain/mark/1.0/\">\n<img src=\"https://i.creativecommons.org/p/mark/1.0/88x31.png\" style=\"border-style: none;\" alt=\"Public Domain Mark\">\n</a>\n<br>\nThis work (<span property=\"dct:title\">Learn Lojban</span>, by <a href=\"https://lojban.pw\" rel=\"dct:creator\"><span property=\"dct:title\">Gleki Arxokuna</span></a>), identified by <a href=\"https://lojban.pw\" rel=\"dct:publisher\"><span property=\"dct:title\">Gleki Arxokuna</span></a>, is free of known copyright restrictions.\n</p>","fullPath":"/app/src/md_pages/welcome.md","toc":[{"depth":"2","value":"‘Learn Lojban’ course","id":"learn-lojban-course","tagName":"h2"},{"depth":"2","value":"Live Lojban chat in the Discord messenger","id":"live-lojban-chat-in-the-discord-messenger","tagName":"h2"},{"depth":"2","value":"Unofficial ‘Complete Lojban Language’ Book, October 2022 Edition","id":"unofficial-complete-lojban-language-book-october-2022-edition","tagName":"h2"},{"depth":"2","value":" la sutysisku - a slick unofficial dictionary","id":"-la-sutysisku---a-slick-unofficial-dictionary","tagName":"h2"},{"depth":"2","value":"License","id":"license","tagName":"h2"}],"imgs":[]}},"__N_SSG":true}