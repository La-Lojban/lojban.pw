ug":["fr","texts","alice-in-wonderland"],"hidden":false,"title":"Alice in Wonderland","directory":"fr"},{"slug":["fr","texts","how-the-enemy-came-to-thlunrana"],"hidden":false,"title":"Comment l'Ennemi est venu à Thlunrana","directory":"fr"},{"slug":["fr","texts","in-a-bitter-hour"],"hidden":false,"title":"In A Bitter Hour","directory":"fr"},{"slug":["fr","texts","jokes"],"hidden":false,"title":"Blagues","directory":"fr"},{"slug":["fr","texts","lords-prayer"],"hidden":false,"title":"The Lord's prayer","directory":"fr"},{"slug":["fr","texts","navy-seal-copypasta"],"hidden":false,"title":"Navy Seals","directory":"fr"},{"slug":["fr","texts","terry-the-tiger-visits-the-big-city"],"hidden":false,"title":"Terry le tigre visite la grande ville","directory":"fr"},{"slug":["fr","texts","the-bad-beginning"],"hidden":false,"title":"The Bad Beginning","directory":"fr"},{"slug":["fr","texts","the-book"],"hidden":false,"title":"Le Livre","directory":"fr"},{"slug":["fr","texts","the-girl-from-ipanema"],"hidden":false,"title":"Garota da Ipanema","directory":"fr"},{"slug":["fr","texts","the-mask"],"hidden":false,"title":"Le Masque","directory":"fr"},{"slug":["fr","texts","the-north-wind-and-the-sun"],"hidden":false,"title":"Le vent du nord et le soleil","directory":"fr"},{"slug":["fr","texts","there-will-come-soft-rains"],"hidden":false,"title":"Il y aura de douces pluies","directory":"fr"},{"slug":["fr","texts","to-kill-a-child"],"hidden":false,"title":"Tuer un enfant","directory":"fr"},{"slug":["fr","texts"],"hidden":false,"title":"📚 Corpus de textes","directory":"fr"},{"slug":["fr","welcome"],"hidden":false,"title":"Qu'est-ce que le Lojban ?","directory":"fr"}],"currentLanguage":"fr","post":{"slug":["fr","texts","lords-prayer"],"title":"The Lord's prayer","hidden":false,"meta.description":"The Lord's prayer","meta.keywords":"Πάτερ Ημών, le jdaselsku, Lord's prayer, Отче наш","meta.type":"korpora","content":"<div class=\"w-full\">\n  <input type=\"checkbox\" id=\"hide-column-dzena_xelso\" class=\"hide-column-checkbox-dzena_xelso\">\n  <label for=\"hide-column-dzena_xelso\" class=\"hide-column-button-dzena_xelso float-left drop-shadow bg-teal-100 hover:bg-teal-600 focus:bg-teal-600 text-gray-900 hover:text-white font-bold leading-normal select-none py-2 px-4\">dzena xelso</label><input type=\"checkbox\" id=\"hide-column-lojbo\" class=\"hide-column-checkbox-lojbo\">\n  <label for=\"hide-column-lojbo\" class=\"hide-column-button-lojbo float-left drop-shadow bg-teal-100 hover:bg-teal-600 focus:bg-teal-600 text-gray-900 hover:text-white font-bold leading-normal select-none py-2 px-4\">lojbo</label><input type=\"checkbox\" id=\"hide-column-glico\" class=\"hide-column-checkbox-glico\">\n  <label for=\"hide-column-glico\" class=\"hide-column-button-glico float-left drop-shadow bg-teal-100 hover:bg-teal-600 focus:bg-teal-600 text-gray-900 hover:text-white font-bold leading-normal select-none py-2 px-4\">English</label><input type=\"checkbox\" id=\"hide-column-rusko\" class=\"hide-column-checkbox-rusko\">\n  <label for=\"hide-column-rusko\" class=\"hide-column-button-rusko float-left drop-shadow bg-teal-100 hover:bg-teal-600 focus:bg-teal-600 text-gray-900 hover:text-white font-bold leading-normal select-none py-2 px-4\">русский</label>\n  <div class=\"clear-both\">\n  <div class=\"w-full overflow-x-auto\">\n    <div class=\"md-typeset__scrollwrap\"><div class=\"md-typeset__scrollwrap\"><div class=\"md-typeset__table\"><table class=\"mt-2 table-fixed max-w-full border font-light dark:border-neutral-500 text-left text-sm\">\n      <thead class=\"border-b italic dark:border-neutral-500\">\n        <tr>\n          <th scope=\"col\" class=\"w-40 p-2 column-class-dzena_xelso\">\n            dzena xelso\n          </th>\n          <th scope=\"col\" class=\"w-40 p-2 column-class-lojbo\">lojbo</th>\n          <th scope=\"col\" class=\"w-40 p-2 column-class-glico\">glico</th>\n          <th scope=\"col\" class=\"w-40 p-2 column-class-rusko\">rusko</th>\n        </tr>\n      </thead>\n      <tbody>\n        <tr class=\"border-b transition duration-300 ease-in-out hover:bg-neutral-100 dark:border-neutral-500 dark:hover:bg-neutral-100\">\n          <td class=\"font-bold text-left align-text-top p-2 column-class-dzena_xelso\">\n            ἑλληνική\n          </td>\n          <td class=\"font-bold text-left align-text-top p-2 column-class-lojbo\">\n            ni'o ni'o bau le lojbo\n          </td>\n          <td class=\"font-bold text-left align-text-top p-2 column-class-glico\">\n            English interlinear translation\n          </td>\n          <td class=\"font-bold text-left align-text-top p-2 column-class-rusko\">\n            Русский подстрочный перевод\n          </td>\n        </tr>\n        <tr class=\"border-b transition duration-300 ease-in-out hover:bg-neutral-100 dark:border-neutral-500 dark:hover:bg-neutral-100\">\n          <td class=\"text-left align-text-top p-2 column-class-dzena_xelso\">\n            Πάτερ Ημών\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-lojbo\">\n            le jdaselsku\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-glico\">\n            Lord's prayer\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-rusko\">\n            Отче наш\n          </td>\n        </tr>\n        <tr class=\"border-b transition duration-300 ease-in-out hover:bg-neutral-100 dark:border-neutral-500 dark:hover:bg-neutral-100\">\n          <td class=\"text-left align-text-top p-2 column-class-dzena_xelso\">\n            Βίβλος\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-lojbo\">\n            .i xrisa cukta\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-glico\">\n            The Bible\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-rusko\">\n            Библия\n          </td>\n        </tr>\n        <tr class=\"border-b transition duration-300 ease-in-out hover:bg-neutral-100 dark:border-neutral-500 dark:hover:bg-neutral-100\">\n          <td class=\"text-left align-text-top p-2 column-class-dzena_xelso\"></td>\n          <td class=\"text-left align-text-top p-2 column-class-lojbo\">\n            .i fanva fa la gleki\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-glico\">\n            Translated by la gleki\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-rusko\">\n            Перевод la gleki\n          </td>\n        </tr>\n        <tr class=\"border-b transition duration-300 ease-in-out hover:bg-neutral-100 dark:border-neutral-500 dark:hover:bg-neutral-100\">\n          <td class=\"text-left align-text-top p-2 column-class-dzena_xelso\">\n            πάτερ ἡμῶν ὁ ἐν τοῖς οὐρανοῖς ἁγιασθήτω τὸ ὄνομά σου\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-lojbo\">\n            doi le patfu be mi be'o ne bu'u lei tsani do'u censa ko'oi fa le\n            cmene be do\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-glico\">\n            O Father ours who is in the heavens, hallowed be the name Yours.\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-rusko\">\n            Отче наш, кто в небесах, пусть святится имя Твоё\n          </td>\n        </tr>\n        <tr class=\"border-b transition duration-300 ease-in-out hover:bg-neutral-100 dark:border-neutral-500 dark:hover:bg-neutral-100\">\n          <td class=\"text-left align-text-top p-2 column-class-dzena_xelso\">\n            ἐλθέτω ἡ βασιλεία σου,\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-lojbo\">\n            .i zvati ko'oi fa le nunturni pe do\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-glico\">\n            Let it come the kingdom Yours.\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-rusko\">\n            пусть придёт царство Твоё,\n          </td>\n        </tr>\n        <tr class=\"border-b transition duration-300 ease-in-out hover:bg-neutral-100 dark:border-neutral-500 dark:hover:bg-neutral-100\">\n          <td class=\"text-left align-text-top p-2 column-class-dzena_xelso\">\n            γενηθήτω τὸ θέλημά σου ὡς ἐν οὐρανῷ καὶ ἐπὶ γῆς\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-lojbo\">\n            .ije fasnu di'ai fe le terzu'e be do ge bu'u lo tsani gi re'o lo\n            terdi\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-glico\">\n            Let it be realized the will Yours.\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-rusko\">\n            пусть реализуется воля Твоя, как в небе, так и на земле.\n          </td>\n        </tr>\n        <tr class=\"border-b transition duration-300 ease-in-out hover:bg-neutral-100 dark:border-neutral-500 dark:hover:bg-neutral-100\">\n          <td class=\"text-left align-text-top p-2 column-class-dzena_xelso\">\n            τὸν ἄρτον ἡμῶν τὸν ἐπιούσιον δὸς ἡμῖν σήμερον\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-lojbo\">\n            .i fe le cidja be mi ku noi jai sarcu cu posydu'a fa do ko'oi fi mi\n            ca le cabdei\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-glico\">\n            Bread ours daily give us today.\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-rusko\">\n            Хлеб наш насущный дай нам сегодня.\n          </td>\n        </tr>\n        <tr class=\"border-b transition duration-300 ease-in-out hover:bg-neutral-100 dark:border-neutral-500 dark:hover:bg-neutral-100\">\n          <td class=\"text-left align-text-top p-2 column-class-dzena_xelso\">\n            καὶ ἄφες ἡμῖν τὰ ὀφειλήματα ἡμῶν, ὡς καὶ ἡμεῖς ἀφίεμεν τοῖς\n            ὀφειλέταις ἡμῶν.\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-lojbo\">\n            .i co'u minde fa do ko'oi mi le se dejni be mi tai lo nu mi co'u\n            minde le se dejni be fi mi\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-glico\">\n            And forgive us the debts ours, as and we forgave the debtors ours.\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-rusko\">\n            И оставь нам долги наши, как и мы оставили должникам нашим.\n          </td>\n        </tr>\n        <tr class=\"border-b transition duration-300 ease-in-out hover:bg-neutral-100 dark:border-neutral-500 dark:hover:bg-neutral-100\">\n          <td class=\"text-left align-text-top p-2 column-class-dzena_xelso\">\n            καὶ μὴ εἰσενέγκῃς ἡμᾶς εἰς πειρασμόν\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-lojbo\">\n            .i na gasnu fa do ko'oi lo nu mi se xlura\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-glico\">\n            And not lead us into temptation\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-rusko\">\n            И не введи нас в искушение,\n          </td>\n        </tr>\n        <tr class=\"border-b transition duration-300 ease-in-out hover:bg-neutral-100 dark:border-neutral-500 dark:hover:bg-neutral-100\">\n          <td class=\"text-left align-text-top p-2 column-class-dzena_xelso\">\n            ἀλλὰ ῥῦσαι ἡμᾶς ἀπὸ τοῦ πονηροῦ\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-lojbo\">\n            .i je ku'i jai gau bandu fa do ko'oi mi le palci\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-glico\">\n            but rescue us from the malicious.\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-rusko\">\n            но спаси нас от хлого.\n          </td>\n        </tr>\n        <tr class=\"border-b transition duration-300 ease-in-out hover:bg-neutral-100 dark:border-neutral-500 dark:hover:bg-neutral-100\">\n          <td class=\"text-left align-text-top p-2 column-class-dzena_xelso\">\n            Ὅτι σοῦ ἐστιν ἡ βασιλεία καὶ ἡ δύναμις καὶ ἡ δόξα εἰς τοὺς αἰῶνας.\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-lojbo\">\n            .i ki'u ku srana be do fa le nu turni .e le se vlipa .e le te misno\n            co'a le nanca be li gei so'i\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-glico\">\n            Because Yours is the kingdom and the power and the glory into the\n            ages.\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-rusko\">\n            Ибо Твоё есть царство и сила и слава в века.\n          </td>\n        </tr>\n        <tr class=\"border-b transition duration-300 ease-in-out hover:bg-neutral-100 dark:border-neutral-500 dark:hover:bg-neutral-100\">\n          <td class=\"text-left align-text-top p-2 column-class-dzena_xelso\">\n            ἀμήν.\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-lojbo\">\n            .i je'u\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-glico\">Amen.</td>\n          <td class=\"text-left align-text-top p-2 column-class-rusko\">Аминь</td>\n        </tr>\n      </tbody>\n    </table></div></div></div>\n  </div>\n</div></div>","fullPath":"/app/src/md_pages/fr/texts/lords-prayer.md","toc":[],"imgs":[]}},"__N_SSG":true}