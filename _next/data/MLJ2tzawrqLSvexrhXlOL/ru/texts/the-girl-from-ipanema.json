{"pageProps":{"posts":[{"fullPath":"en/texts/the-girl-from-ipanema","language":"en"},{"fullPath":"es/texts/the-girl-from-ipanema","language":"es"},{"fullPath":"fr/texts/the-girl-from-ipanema","language":"fr"},{"fullPath":"pt/texts/the-girl-from-ipanema","language":"pt"}],"siblingPosts":[],"currentLanguage":"ru","post":{"slug":["ru","texts","the-girl-from-ipanema"],"title":"Garota da Ipanema","hidden":false,"meta.description":"Garota da Ipanema","meta.keywords":".i la'e lu le nixli be la .ipaneman. lu'u, Garota de Ipanema., The Girl from Ipanema","meta.type":"korpora","content":"<div class=\"w-full\">\n  <input type=\"checkbox\" id=\"hide-column-lojbo\" class=\"hide-column-checkbox-lojbo\">\n  <label for=\"hide-column-lojbo\" class=\"hide-column-button-lojbo float-left drop-shadow bg-blue-500 hover:bg-blue-600 focus:bg-blue-600 text-white font-bold leading-normal select-none py-2 px-4\">lojbo</label><input type=\"checkbox\" id=\"hide-column-porto\" class=\"hide-column-checkbox-porto\">\n  <label for=\"hide-column-porto\" class=\"hide-column-button-porto float-left drop-shadow bg-blue-500 hover:bg-blue-600 focus:bg-blue-600 text-white font-bold leading-normal select-none py-2 px-4\">português</label><input type=\"checkbox\" id=\"hide-column-glico\" class=\"hide-column-checkbox-glico\">\n  <label for=\"hide-column-glico\" class=\"hide-column-button-glico float-left drop-shadow bg-blue-500 hover:bg-blue-600 focus:bg-blue-600 text-white font-bold leading-normal select-none py-2 px-4\">English</label>\n  <div class=\"clear-both\">\n  <div class=\"w-full overflow-x-auto\">\n    <div class=\"md-typeset__scrollwrap\"><div class=\"md-typeset__scrollwrap\"><div class=\"md-typeset__table\"><table class=\"mt-2 table-fixed max-w-full border font-light dark:border-neutral-500 text-left text-sm\">\n      <thead class=\"border-b italic dark:border-neutral-500\">\n        <tr>\n          <th scope=\"col\" class=\"w-40 p-2 column-class-lojbo\">lojbo</th>\n          <th scope=\"col\" class=\"w-40 p-2 column-class-porto\">porto</th>\n          <th scope=\"col\" class=\"w-40 p-2 column-class-glico\">glico</th>\n        </tr>\n      </thead>\n      <tbody>\n        <tr class=\"border-b transition duration-300 ease-in-out hover:bg-neutral-100 dark:border-neutral-500 dark:hover:bg-neutral-100\">\n          <td class=\"font-bold text-left align-text-top p-2 column-class-lojbo\">\n            ni'o ni'o bau le lojbo\n          </td>\n          <td class=\"font-bold text-left align-text-top p-2 column-class-porto\">\n            original\n          </td>\n          <td class=\"font-bold text-left align-text-top p-2 column-class-glico\">\n            English translation\n          </td>\n        </tr>\n        <tr class=\"border-b transition duration-300 ease-in-out hover:bg-neutral-100 dark:border-neutral-500 dark:hover:bg-neutral-100\">\n          <td class=\"text-left align-text-top p-2 column-class-lojbo\">\n            .i la'e lu le nixli be la .ipaneman. lu'u\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-porto\">\n            Garota de Ipanema.\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-glico\">\n            The Girl from Ipanema\n          </td>\n        </tr>\n        <tr class=\"border-b transition duration-300 ease-in-out hover:bg-neutral-100 dark:border-neutral-500 dark:hover:bg-neutral-100\">\n          <td class=\"text-left align-text-top p-2 column-class-lojbo\">\n            .i finti fa la.viNIsi,us.djimoRA,is.\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-porto\">\n            Vinicius de Moraes\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-glico\">\n            by Vinicius de Moraes\n          </td>\n        </tr>\n        <tr class=\"border-b transition duration-300 ease-in-out hover:bg-neutral-100 dark:border-neutral-500 dark:hover:bg-neutral-100\">\n          <td class=\"text-left align-text-top p-2 column-class-lojbo\">\n            .i la gleki cu fanva\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-porto\">\n            original\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-glico\">\n            Translated by la gleki\n          </td>\n        </tr>\n        <tr class=\"border-b transition duration-300 ease-in-out hover:bg-neutral-100 dark:border-neutral-500 dark:hover:bg-neutral-100\">\n          <td class=\"text-left align-text-top p-2 column-class-lojbo\">\n            .i ko catlu le dacti noi traji melbi\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-porto\">\n            Olha que coisa mais linda\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-glico\">\n            Look, what a beautiful thing\n          </td>\n        </tr>\n        <tr class=\"border-b transition duration-300 ease-in-out hover:bg-neutral-100 dark:border-neutral-500 dark:hover:bg-neutral-100\">\n          <td class=\"text-left align-text-top p-2 column-class-lojbo\">\n            gi'e mulno le ka nobli\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-porto\">\n            Mais cheia de graça\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-glico\">\n            So filled with grace.\n          </td>\n        </tr>\n        <tr class=\"border-b transition duration-300 ease-in-out hover:bg-neutral-100 dark:border-neutral-500 dark:hover:bg-neutral-100\">\n          <td class=\"text-left align-text-top p-2 column-class-lojbo\">\n            .i du ra poi du le nixli\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-porto\">\n            É ela, a menina\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-glico\">\n            It's her, the girl\n          </td>\n        </tr>\n        <tr class=\"border-b transition duration-300 ease-in-out hover:bg-neutral-100 dark:border-neutral-500 dark:hover:bg-neutral-100\">\n          <td class=\"text-left align-text-top p-2 column-class-lojbo\">\n            noi klama gi'e bancu muvdu\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-porto\">\n            Que vem e que passa\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-glico\">\n            who comes and who passes by.\n          </td>\n        </tr>\n        <tr class=\"border-b transition duration-300 ease-in-out hover:bg-neutral-100 dark:border-neutral-500 dark:hover:bg-neutral-100\">\n          <td class=\"text-left align-text-top p-2 column-class-lojbo\">\n            ca le nu ke'a pluka slilu\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-porto\">\n            Num doce balanço\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-glico\">\n            In her sweet swing\n          </td>\n        </tr>\n        <tr class=\"border-b transition duration-300 ease-in-out hover:bg-neutral-100 dark:border-neutral-500 dark:hover:bg-neutral-100\">\n          <td class=\"text-left align-text-top p-2 column-class-lojbo\">\n            vau fe le xamsi\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-porto\">\n            A caminho do mar\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-glico\">\n            on the way to the sea\n          </td>\n        </tr>\n        <tr class=\"border-b transition duration-300 ease-in-out hover:bg-neutral-100 dark:border-neutral-500 dark:hover:bg-neutral-100\">\n          <td class=\"text-left align-text-top p-2 column-class-lojbo\">\n            .i doi le nixli noi se xadni le sloska\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-porto\">\n            Moça do corpo dourado\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-glico\">\n            Girl with body of gold\n          </td>\n        </tr>\n        <tr class=\"border-b transition duration-300 ease-in-out hover:bg-neutral-100 dark:border-neutral-500 dark:hover:bg-neutral-100\">\n          <td class=\"text-left align-text-top p-2 column-class-lojbo\">\n            noi se krasi le solri be la .ipaneman.\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-porto\">\n            Do sol de Ipanema\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-glico\">\n            From the sun of Ipanema\n          </td>\n        </tr>\n        <tr class=\"border-b transition duration-300 ease-in-out hover:bg-neutral-100 dark:border-neutral-500 dark:hover:bg-neutral-100\">\n          <td class=\"text-left align-text-top p-2 column-class-lojbo\">\n            i le nu ra slilu\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-porto\">\n            O seu balançado\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-glico\">\n            Her swing\n          </td>\n        </tr>\n        <tr class=\"border-b transition duration-300 ease-in-out hover:bg-neutral-100 dark:border-neutral-500 dark:hover:bg-neutral-100\">\n          <td class=\"text-left align-text-top p-2 column-class-lojbo\">\n            cu zmadu lo'e se pemci\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-porto\">\n            É mais que um poema\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-glico\">\n            is more than a poem\n          </td>\n        </tr>\n        <tr class=\"border-b transition duration-300 ease-in-out hover:bg-neutral-100 dark:border-neutral-500 dark:hover:bg-neutral-100\">\n          <td class=\"text-left align-text-top p-2 column-class-lojbo\">\n            gi'e du le fasnu co traji melbi\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-porto\">\n            É a coisa mais linda\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-glico\">\n            She is the most beautiful thing\n          </td>\n        </tr>\n        <tr class=\"border-b transition duration-300 ease-in-out hover:bg-neutral-100 dark:border-neutral-500 dark:hover:bg-neutral-100\">\n          <td class=\"text-left align-text-top p-2 column-class-lojbo\">\n            poi mi pu'i viska le nu ke'a bancu muvdu\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-porto\">\n            Que eu já vi passar\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-glico\">\n            that I've ever seen pass by\n          </td>\n        </tr>\n        <tr class=\"border-b transition duration-300 ease-in-out hover:bg-neutral-100 dark:border-neutral-500 dark:hover:bg-neutral-100\">\n          <td class=\"text-left align-text-top p-2 column-class-lojbo\">\n            .i .oi ki'u ma mi tai kansa no da\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-porto\">\n            Ah, porque estou tão sozinho\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-glico\">\n            Ah, why am I so lonely?\n          </td>\n        </tr>\n        <tr class=\"border-b transition duration-300 ease-in-out hover:bg-neutral-100 dark:border-neutral-500 dark:hover:bg-neutral-100\">\n          <td class=\"text-left align-text-top p-2 column-class-lojbo\">\n            .i .oi ki'u ma ro da tai se badri\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-porto\">\n            Ah, porque tudo é tão triste\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-glico\">\n            Ah, why is everything so sad?\n          </td>\n        </tr>\n        <tr class=\"border-b transition duration-300 ease-in-out hover:bg-neutral-100 dark:border-neutral-500 dark:hover:bg-neutral-100\">\n          <td class=\"text-left align-text-top p-2 column-class-lojbo\">\n            .i .oi doi le melbi noi zasti\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-porto\">\n            Ah, a beleza que existe\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-glico\">\n            Ah, the beauty that exists\n          </td>\n        </tr>\n        <tr class=\"border-b transition duration-300 ease-in-out hover:bg-neutral-100 dark:border-neutral-500 dark:hover:bg-neutral-100\">\n          <td class=\"text-left align-text-top p-2 column-class-lojbo\">\n            joi le melbi noi na co'e mi po'o\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-porto\">\n            A beleza que não é só minha\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-glico\">\n            The beauty that is not solely mine\n          </td>\n        </tr>\n        <tr class=\"border-b transition duration-300 ease-in-out hover:bg-neutral-100 dark:border-neutral-500 dark:hover:bg-neutral-100\">\n          <td class=\"text-left align-text-top p-2 column-class-lojbo\">\n            gi'e ji'a bancu co kansa be no da\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-porto\">\n            Que também passa sozinha\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-glico\">\n            That also passes by alone\n          </td>\n        </tr>\n        <tr class=\"border-b transition duration-300 ease-in-out hover:bg-neutral-100 dark:border-neutral-500 dark:hover:bg-neutral-100\">\n          <td class=\"text-left align-text-top p-2 column-class-lojbo\">\n            .i .au da'i ra djuno\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-porto\">\n            Ah, se ela soubesse\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-glico\">\n            Ah, if she knew\n          </td>\n        </tr>\n        <tr class=\"border-b transition duration-300 ease-in-out hover:bg-neutral-100 dark:border-neutral-500 dark:hover:bg-neutral-100\">\n          <td class=\"text-left align-text-top p-2 column-class-lojbo\">\n            le du'u ca le nu ra bancu vau\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-porto\">\n            Que quando ela passa\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-glico\">\n            That when she passes by\n          </td>\n        </tr>\n        <tr class=\"border-b transition duration-300 ease-in-out hover:bg-neutral-100 dark:border-neutral-500 dark:hover:bg-neutral-100\">\n          <td class=\"text-left align-text-top p-2 column-class-lojbo\">\n            le munje noi ca'o cisma\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-porto\">\n            O mundo sorrindo\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-glico\">\n            The whole smiling world\n          </td>\n        </tr>\n        <tr class=\"border-b transition duration-300 ease-in-out hover:bg-neutral-100 dark:border-neutral-500 dark:hover:bg-neutral-100\">\n          <td class=\"text-left align-text-top p-2 column-class-lojbo\">\n            cu culno le ka nobli vau mo'u\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-porto\">\n            Se enche de graça\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-glico\">\n            gets filled with grace.\n          </td>\n        </tr>\n        <tr class=\"border-b transition duration-300 ease-in-out hover:bg-neutral-100 dark:border-neutral-500 dark:hover:bg-neutral-100\">\n          <td class=\"text-left align-text-top p-2 column-class-lojbo\">\n            gi'e co'a traji melbi\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-porto\">\n            E fica mais lindo\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-glico\">\n            And becomes more beautiful\n          </td>\n        </tr>\n        <tr class=\"border-b transition duration-300 ease-in-out hover:bg-neutral-100 dark:border-neutral-500 dark:hover:bg-neutral-100\">\n          <td class=\"text-left align-text-top p-2 column-class-lojbo\">\n            vau ri'a le nu prami\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-porto\">\n            Por causa do amor\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-glico\">\n            Because of love.\n          </td>\n        </tr>\n      </tbody>\n    </table></div></div></div>\n  </div>\n</div></div>","fullPath":"/app/src/md_pages/ru/texts/the-girl-from-ipanema.md","toc":[],"imgs":[]}},"__N_SSG":true}