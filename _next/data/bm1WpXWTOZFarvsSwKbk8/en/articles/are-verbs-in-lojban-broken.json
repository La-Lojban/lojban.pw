,"directory":"fr"},{"slug":["fr","texts","the-mask"],"hidden":false,"title":"Le Masque","directory":"fr"},{"slug":["fr","texts","the-north-wind-and-the-sun"],"hidden":false,"title":"Le vent du nord et le soleil","directory":"fr"},{"slug":["fr","texts","there-will-come-soft-rains"],"hidden":false,"title":"Il y aura de douces pluies","directory":"fr"},{"slug":["fr","texts","to-kill-a-child"],"hidden":false,"title":"To kill a child","directory":"fr"},{"slug":["fr","texts"],"hidden":false,"title":"📚 Corpus de textes","directory":"fr"},{"slug":["fr","welcome"],"hidden":false,"title":"Qu'est-ce que le Lojban ?","directory":"fr"},{"slug":["pt","articles","are-verbs-in-lojban-broken"],"hidden":false,"title":"Os Verbos em Lojban estão Quebrados?","directory":"pt"},{"slug":["pt","articles","complete-lojban-language"],"hidden":false,"title":"📕 Idioma completo","directory":"pt"},{"slug":["pt","articles","dialects"],"hidden":false,"title":"Dialectos do Lojban","directory":"pt"},{"slug":["pt","articles","how-to-say-play-in-lojban"],"hidden":false,"title":"Como dizer \"jogar\" em Lojban","directory":"pt"},{"slug":["pt","articles","krulermorna"],"hidden":false,"title":"alfabeto krulermorna","directory":"pt"},{"slug":["pt","articles","live_chat"],"hidden":false,"title":"💬 Chat","directory":"pt"},{"slug":["pt","articles","lojban-and-speed-of-thought"],"hidden":false,"title":"Língua Lojban e velocidade do pensamento","directory":"pt"},{"slug":["pt","articles","sutysisku-picture-dictionary"],"hidden":false,"title":"la sutysisku: dicionário de imagens","directory":"pt"},{"slug":["pt","articles","sutysisku_semantic_search"],"hidden":false,"title":"la sutysisku e busca de similaridade","directory":"pt"},{"slug":["pt","books","core-lojban"],"hidden":false,"title":"📝 Ensaio 'Core Lojban'","directory":"pt"},{"slug":["pt","books","learn-lojban"],"hidden":false,"title":"🎓 Aprenda Lojban","directory":"pt"},{"slug":["pt","humour","sapir-whorf-hypothesis-confirmed"],"hidden":false,"title":"Hipóte