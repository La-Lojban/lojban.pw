tory":"es"},{"slug":["es","texts","alice-in-wonderland"],"hidden":false,"title":"Alice in Wonderland","directory":"es"},{"slug":["es","texts","how-the-enemy-came-to-thlunrana"],"hidden":false,"title":"De cómo llegó el enemigo a Thulnrana.","directory":"es"},{"slug":["es","texts","in-a-bitter-hour"],"hidden":false,"title":"In A Bitter Hour","directory":"es"},{"slug":["es","texts","jokes"],"hidden":false,"title":"Jokes","directory":"es"},{"slug":["es","texts","lords-prayer"],"hidden":false,"title":"The Lord's prayer","directory":"es"},{"slug":["es","texts","navy-seal-copypasta"],"hidden":false,"title":"Navy Seals","directory":"es"},{"slug":["es","texts","terry-the-tiger-visits-the-big-city"],"hidden":false,"title":"Terry el Tigre Visita la Gran Ciudad","directory":"es"},{"slug":["es","texts","the-bad-beginning"],"hidden":false,"title":"The Bad Beginning","directory":"es"},{"slug":["es","texts","the-book"],"hidden":false,"title":"The Book","directory":"es"},{"slug":["es","texts","the-girl-from-ipanema"],"hidden":false,"title":"Garota da Ipanema","directory":"es"},{"slug":["es","texts","the-mask"],"hidden":false,"title":"La máscara","directory":"es"},{"slug":["es","texts","the-north-wind-and-the-sun"],"hidden":false,"title":"The North Wind","directory":"es"},{"slug":["es","texts","there-will-come-soft-rains"],"hidden":false,"title":"Soft rains","directory":"es"},{"slug":["es","texts","to-kill-a-child"],"hidden":false,"title":"To kill a child","directory":"es"},{"slug":["es","texts"],"hidden":false,"title":"📚 Corpus de textos","directory":"es"},{"slug":["es","welcome"],"hidden":false,"title":"¿Qué es Lojban?","directory":"es"}],"currentLanguage":"es","post":{"slug":["es","texts","lords-prayer"],"title":"The Lord's prayer","hidden":false,"meta.description":"The Lord's prayer","meta.keywords":"Πάτερ Ημών, le jdaselsku, Lord's prayer","meta.type":"korpora","content":"<div class=\"w-full\">\n  <input type=\"checkbox\" id=\"hide-column-ἑλληνική\" class=\"hide-column-checkbox-ἑλληνική\">\n  <label for=\"hide-column-ἑλληνική\" class=\"hide-column-button-ἑλληνική float-left drop-shadow bg-blue-500 hover:bg-blue-600 focus:bg-blue-600 text-white font-bold leading-normal select-none py-2 px-4\">ἑλληνική</label><input type=\"checkbox\" id=\"hide-column-lojbo\" class=\"hide-column-checkbox-lojbo\">\n  <label for=\"hide-column-lojbo\" class=\"hide-column-button-lojbo float-left drop-shadow bg-blue-500 hover:bg-blue-600 focus:bg-blue-600 text-white font-bold leading-normal select-none py-2 px-4\">lojbo</label><input type=\"checkbox\" id=\"hide-column-glico\" class=\"hide-column-checkbox-glico\">\n  <label for=\"hide-column-glico\" class=\"hide-column-button-glico float-left drop-shadow bg-blue-500 hover:bg-blue-600 focus:bg-blue-600 text-white font-bold leading-normal select-none py-2 px-4\">English</label>\n  <div class=\"clear-both\">\n  <div class=\"w-full overflow-x-auto\">\n    <div class=\"md-typeset__scrollwrap\"><div class=\"md-typeset__scrollwrap\"><div class=\"md-typeset__table\"><table class=\"mt-2 table-fixed max-w-full border font-light dark:border-neutral-500 text-left text-sm\">\n      <thead class=\"border-b italic dark:border-neutral-500\">\n        <tr>\n          <th scope=\"col\" class=\"w-40 p-2 column-class-ἑλληνική\">ἑλληνική</th>\n          <th scope=\"col\" class=\"w-40 p-2 column-class-lojbo\">lojbo</th>\n          <th scope=\"col\" class=\"w-40 p-2 column-class-glico\">glico</th>\n        </tr>\n      </thead>\n      <tbody>\n        <tr class=\"border-b transition duration-300 ease-in-out hover:bg-neutral-100 dark:border-neutral-500 dark:hover:bg-neutral-100\">\n          <td class=\"font-bold text-left align-text-top p-2 column-class-ἑλληνική\">\n            ἑλληνική\n          </td>\n          <td class=\"font-bold text-left align-text-top p-2 column-class-lojbo\">\n            ni'o ni'o bau le lojbo\n          </td>\n          <td class=\"font-bold text-left align-text-top p-2 column-class-glico\">\n            English translation\n          </td>\n        </tr>\n        <tr class=\"border-b transition duration-300 ease-in-out hover:bg-neutral-100 dark:border-neutral-500 dark:hover:bg-neutral-100\">\n          <td class=\"text-left align-text-top p-2 column-class-ἑλληνική\">\n            Πάτερ Ημών\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-lojbo\">\n            le jdaselsku\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-glico\">\n            Lord's prayer\n          </td>\n        </tr>\n        <tr class=\"border-b transition duration-300 ease-in-out hover:bg-neutral-100 dark:border-neutral-500 dark:hover:bg-neutral-100\">\n          <td class=\"text-left align-text-top p-2 column-class-ἑλληνική\">\n            Βίβλος\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-lojbo\">\n            .i xrisa cukta\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-glico\">\n            The Bible\n          </td>\n        </tr>\n        <tr class=\"border-b transition duration-300 ease-in-out hover:bg-neutral-100 dark:border-neutral-500 dark:hover:bg-neutral-100\">\n          <td class=\"text-left align-text-top p-2 column-class-ἑλληνική\"></td>\n          <td class=\"text-left align-text-top p-2 column-class-lojbo\">\n            .i fanva fa la gleki\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-glico\">KJV</td>\n        </tr>\n        <tr class=\"border-b transition duration-300 ease-in-out hover:bg-neutral-100 dark:border-neutral-500 dark:hover:bg-neutral-100\">\n          <td class=\"text-left align-text-top p-2 column-class-ἑλληνική\">\n            πάτερ ἡμῶν ὁ ἐν τοῖς οὐρανοῖς ἁγιασθήτω τὸ ὄνομά σου\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-lojbo\">\n            doi le patfu be mi be'o ne bu'u lei tsani do'u censa ko'oi fa le\n            cmene be do\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-glico\">\n            Our Father in heaven, hallowed be your name,\n          </td>\n        </tr>\n        <tr class=\"border-b transition duration-300 ease-in-out hover:bg-neutral-100 dark:border-neutral-500 dark:hover:bg-neutral-100\">\n          <td class=\"text-left align-text-top p-2 column-class-ἑλληνική\">\n            ἐλθέτω ἡ βασιλεία σου,\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-lojbo\">\n            .i zvati ko'oi fa le nunturni pe do\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-glico\">\n            your kingdom come,\n          </td>\n        </tr>\n        <tr class=\"border-b transition duration-300 ease-in-out hover:bg-neutral-100 dark:border-neutral-500 dark:hover:bg-neutral-100\">\n          <td class=\"text-left align-text-top p-2 column-class-ἑλληνική\">\n            γενηθήτω τὸ θέλημά σου ὡς ἐν οὐρανῷ καὶ ἐπὶ γῆς\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-lojbo\">\n            .ije fasnu di'ai fe le terzu'e be do ge bu'u lo tsani gi re'o lo\n            terdi\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-glico\">\n            your will be done, on earth as in heaven.\n          </td>\n        </tr>\n        <tr class=\"border-b transition duration-300 ease-in-out hover:bg-neutral-100 dark:border-neutral-500 dark:hover:bg-neutral-100\">\n          <td class=\"text-left align-text-top p-2 column-class-ἑλληνική\">\n            τὸν ἄρτον ἡμῶν τὸν ἐπιούσιον δὸς ἡμῖν σήμερον\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-lojbo\">\n            .i fe le cidja be mi ku noi jai sarcu cu posydu'a fa do ko'oi fi mi\n            ca le cabdei\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-glico\">\n            Give us today our daily bread.\n          </td>\n        </tr>\n        <tr class=\"border-b transition duration-300 ease-in-out hover:bg-neutral-100 dark:border-neutral-500 dark:hover:bg-neutral-100\">\n          <td class=\"text-left align-text-top p-2 column-class-ἑλληνική\">\n            καὶ ἄφες ἡμῖν τὰ ὀφειλήματα ἡμῶν, ὡς καὶ ἡμεῖς ἀφίεμεν τοῖς\n            ὀφειλέταις ἡμῶν.\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-lojbo\">\n            .i co'u minde fa do ko'oi mi le se dejni be mi tai lo nu mi co'u\n            minde le se dejni be fi mi\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-glico\">\n            Forgive us our sins as we forgive those who sin against us.\n          </td>\n        </tr>\n        <tr class=\"border-b transition duration-300 ease-in-out hover:bg-neutral-100 dark:border-neutral-500 dark:hover:bg-neutral-100\">\n          <td class=\"text-left align-text-top p-2 column-class-ἑλληνική\">\n            καὶ μὴ εἰσενέγκῃς ἡμᾶς εἰς πειρασμόν\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-lojbo\">\n            .i na gasnu fa do ko'oi mi lo nu mi se xlura\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-glico\">\n            Save us from the time of trial\n          </td>\n        </tr>\n        <tr class=\"border-b transition duration-300 ease-in-out hover:bg-neutral-100 dark:border-neutral-500 dark:hover:bg-neutral-100\">\n          <td class=\"text-left align-text-top p-2 column-class-ἑλληνική\">\n            ἀλλὰ ῥῦσαι ἡμᾶς ἀπὸ τοῦ πονηροῦ\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-lojbo\">\n            .i je ku'i jai gau bandu fa do ko'oi mi le palci\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-glico\">\n            and deliver us from evil.\n          </td>\n        </tr>\n        <tr class=\"border-b transition duration-300 ease-in-out hover:bg-neutral-100 dark:border-neutral-500 dark:hover:bg-neutral-100\">\n          <td class=\"text-left align-text-top p-2 column-class-ἑλληνική\">\n            Ὅτι σοῦ ἐστιν ἡ βασιλεία καὶ ἡ δύναμις καὶ ἡ δόξα εἰς τοὺς αἰῶνας.\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-lojbo\">\n            .i ki'u ku srana be do fa le nu turni .e le se vlipa .e le te misno\n            poi nanca li gei so'i\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-glico\">\n            For the kingdom, the power, and the glory are yours now and for\n            ever.\n          </td>\n        </tr>\n        <tr class=\"border-b transition duration-300 ease-in-out hover:bg-neutral-100 dark:border-neutral-500 dark:hover:bg-neutral-100\">\n          <td class=\"text-left align-text-top p-2 column-class-ἑλληνική\">\n            ἀμήν.\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-lojbo\">\n            .i je'u\n          </td>\n          <td class=\"text-left align-text-top p-2 column-class-glico\">Amen.</td>\n        </tr>\n      </tbody>\n    </table></div></div></div>\n  </div>\n</div></div>","fullPath":"/app/src/md_pages/es/texts/lords-prayer.md","toc":[],"imgs":[]}},"__N_SSG":true}